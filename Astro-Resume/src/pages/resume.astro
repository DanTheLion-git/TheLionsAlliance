---
import Layout from "../layouts/ResumeLayout.astro";
import { getPosts, type WPPost } from "../lib/wp";
import { decodeHTML } from "../lib/html";

const posts: WPPost[] = await getPosts(3); // show 3 latest on the frontpage
---

<Layout title="The Lions Alliance">
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-main">
        <p class="hero-tagline">PORTFOLIO · WEB · 3D</p>
        <h1 class="hero-title">
          Hi, I'm <span class="hero-highlight">Daniël</span>
        </h1>
        <p class="hero-text">
            I do a lot of really cool things with programming, 3D, storytelling, and electronics.
            This portfolio contains both my development blog where I write about my projects as I am working on them, as well as a showcase of the finished projects.
        </p>
      </div>

      <aside class="hero-side">
        <div class="pill">Currently exploring</div>
        <!-- <h2 class="hero-side-title">side title</h2> -->
        <ul class="hero-side-list">
          <li>• Touch Screen Table</li>
          <li>• Robotic Horse</li>
          <li>• Brief aan Jan</li>
          <li>• Amsterdam 2.0</li>
          <li>• Puzzle Lantern</li>
          <li>• Home Streaming</li>
        </ul>
      </aside>
    </div>
  </section>

  <section id="experience" class="section">
    <div class="section-header">
      <h2 class="section-title">Work Experience</h2>
      <p class="section-subtitle">What I’ve worked on professionally</p>
    </div>

    <div class="cards-grid">
      <article class="card">
        <h3 class="card-title">Your Job Title</h3>
        <p class="card-meta">Company Name · 2023 — Present</p>
        <p>
          Short description of what you did. Focus on impact, not just tasks.
        </p>
        <ul>
          <li>• Built X that improved Y</li>
          <li>• Worked with Z technologies</li>
          <li>• Collaborated with A/B teams</li>
        </ul>
      </article>

      <article class="card">
        <h3 class="card-title">Previous Role</h3>
        <p class="card-meta">Company Name · 2021 — 2023</p>
        <p>
          Another short, impact-focused description.
        </p>
      </article>
    </div>
  </section>

  <section id="education" class="section">
    <div class="section-header">
      <h2 class="section-title">Education</h2>
      <p class="section-subtitle">Background and learning</p>
    </div>

    <div class="cards-grid">
      <article class="card">
        <h3 class="card-title">Your Degree</h3>
        <p class="card-meta">University Name · 2018 — 2022</p>
        <p>
          Optional: focus area, thesis, or notable projects.
        </p>
      </article>
    </div>
  </section>

  <section id="work" class="section">
    <div class="section-header">
      <h2 class="section-title">Finished Projects</h2>
      <p class="section-subtitle">A quick overview of some of the projects I have finished</p>
    </div>

    <div class="cards-grid">
      <article class="card">
        <h3 class="card-title">VR Voyage</h3>
        <p class="card-meta">VR Blender Experience</p>
        <p>
          A VR experience created in Blender where the user can experience Amsterdam in the year 1600 while on board a boat. Meeting various historic characters along the way.
        </p>
      </article>

      <article class="card">
        <h3 class="card-title">Martens Beton</h3>
        <p class="card-meta">Marketing Animation Video</p>
        <p>
          A short video created in Blender and After Effects that showcases Martens Beton's new productline; the Qube system.
        </p>
      </article>

      <article class="card">
        <h3 class="card-title">Python Autorigger</h3>
        <p class="card-meta">Animation Automation Tool</p>
        <p>
          A web based automatic rigging tool for 3D characters built using Autodesk Maya's PyMel and Flask. It allows users to upload their 3D character models and automatically generates a rig for them, making the animation process much faster and more efficient.
        </p>
      </article>

    </div>
  </section>

  <section id="writing" class="section">
    <div class="section-header">
      <h2 class="section-title">Latest Blogposts</h2>
      <a href="/blog/" class="section-link">View all posts →</a>
    </div>

    {posts.length === 0 && (
      <p>No posts found yet. Once you publish on WordPress, they’ll show up here.</p>
    )}

    {posts.length > 0 && (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-card">
            <a href={`/blog/${post.slug}/`} class="post-title">
              {decodeHTML(post.title.rendered)}
            </a>

            <p class="post-meta">
              <time datetime={post.date}>
                {new Date(post.date).toLocaleDateString("en-GB", {
                  year: "numeric",
                  month: "short",
                  day: "2-digit",
                })}
              </time>
            </p>

            <p class="post-excerpt" set:html={post.excerpt.rendered} />
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Get in contact</h2>
    </div>
    <div class="contact-block">
      <p>
        Feel free to reach out if you are interested in my work, have any questions, or just want to say hi!
      </p>
      <p>
        You can reach me at
        <a href="mailto:info.mvdvl@gmail.com">info.mvdvl@gmail.com</a>.
      </p>
    </div>
  </section>
</Layout>
