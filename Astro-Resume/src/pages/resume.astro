---
import Layout from "../layouts/ResumeLayout.astro";
import { getPosts, type WPPost } from "../lib/wp";
import { decodeHTML } from "../lib/html";
const posts: WPPost[] = await getPosts(3);
---
<Layout title="The Lions Alliance" theme="dark">
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-main">
        <p class="hero-tagline">PORTFOLIO · WEB · 3D</p>
        <h1 class="hero-title">Hi, I'm <span class="hero-highlight">Daniël</span></h1>
        <p class="hero-text">
          I do a lot of really cool things with programming, 3D, storytelling,
          and electronics. This portfolio contains both my development blog
          where I write about my projects as I am working on them, as well as a
          showcase of the finished projects.
        </p>
        <div class="hero-actions">
          <a href="https://www.youtube.com/@DanTheLionVFX" class="button-primary" target="_blank" rel="noopener noreferrer">YouTube</a>
          <a href="https://sketchfab.com/superwortel" class="button-ghost" target="_blank" rel="noopener noreferrer">Sketchfab</a>
          <a href="https://daanvanleeuwen.itch.io" class="button-ghost" target="_blank" rel="noopener noreferrer">Itch.io</a>
        </div>
      </div>
      <aside class="hero-side">
        <div class="pill">Currently exploring</div>
        <ul class="hero-side-list">
          <li>• Touch Screen Table</li>
          <li>• Robotic Horse</li>
          <li>• Brief aan Jan</li>
          <li>• Amsterdam 2.0</li>
          <li>• Puzzle Lantern</li>
          <li>• Home Streaming</li>
        </ul>
      </aside>
    </div>
  </section>

  <section id="experience" class="section">
    <div class="section-header">
      <h2 class="section-title">Work Experience</h2>
      <p class="section-subtitle">A short overview of my professional background</p>
    </div>
    <div class="contact-block">
      <ul class="post-list">
        <li class="post-card">
          <h3 class="card-title">Software Developer</h3>
          <p class="post-meta">Pebble · 2026-02 — present</p>
          <p class="post-excerpt">Worked with ASP.NET, C#, and Azure enable data access at ASML by developing a web application that streamlined setting up retention policies for data storage.</p>
        </li>
        <li class="post-card">
          <h3 class="card-title">3D Animation and Video Developer</h3>
          <p class="post-meta">Enversed Studios · 2023-12 — 2026-02</p>
          <p class="post-excerpt">Created 3D animations and videos using Blender and After Effects. Used Xsens motion capture and Reallusion to create realistic character animations. Used Marvelous Designer for custom clothing. Performed on-site recordings with and without greenscreen.</p>
        </li>
      </ul>
      <details style="margin-top: 0.75rem;">
        <summary class="section-link" style="cursor: pointer;">Show more experience</summary>
        <ul class="post-list" style="margin-top: 0.9rem;">
          <li class="post-card">
            <h3 class="card-title">Graduation Internship</h3>
            <p class="post-meta">Het Nieuwe Kader · 2023-01 — 2023-07</p>
            <p class="post-excerpt">Created a custom web-based automatic rigging tool to enable clients to quickly rig their 3D characters in order to preview remotely directed motion capture sessions.</p>
          </li>
          <li class="post-card">
            <h3 class="card-title">Intern Product Specialist</h3>
            <p class="post-meta">Movella/Xsens · 2022-03 — 2022-08</p>
            <p class="post-excerpt">Worked on the documentation for the Xsens MVN Animate Pro software and hardware. Performed demo's for customers and provided technical support.</p>
          </li>
          <li class="post-card">
            <h3 class="card-title">Junior VR Developer</h3>
            <p class="post-meta">Wired Workers · 2020-07 — 2021-08</p>
            <p class="post-excerpt">Worked part-time on developing a WebGL-based digital showroom for a range of collaborative robot arms. Created 3D models and animations for several applications.</p>
          </li>
        </ul>
      </details>
    </div>
  </section>

  <section id="work" class="section">
    <div class="section-header">
      <h2 class="section-title">Finished Projects</h2>
      <p class="section-subtitle">Drag to rotate · click a project to learn more</p>
    </div>
    <div id="podium-wrapper" class="podium-wrapper">
      <canvas id="podium-canvas"></canvas>
      <aside id="proj-panel" class="proj-panel" aria-hidden="true" aria-label="Project details">
        <button id="proj-close" aria-label="Close">&#x2715;</button>
        <h3 id="proj-title"></h3>
        <p  id="proj-meta"  class="post-meta"></p>
        <p  id="proj-desc"  class="post-excerpt"></p>
        <div id="proj-links" class="proj-links"></div>
      </aside>
    </div>
  </section>

  <section id="writing" class="section">
    <div class="section-header">
      <h2 class="section-title">Latest Blogposts</h2>
      <a href="/blog/" class="section-link">View all posts →</a>
    </div>
    {posts.length === 0 && <p>No posts found yet.</p>}
    {posts.length > 0 && (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-card">
            <a href={`/blog/${post.slug}/`} class="post-title">{decodeHTML(post.title.rendered)}</a>
            <p class="post-meta"><time datetime={post.date}>{new Date(post.date).toLocaleDateString("en-GB",{year:"numeric",month:"short",day:"2-digit"})}</time></p>
            <p class="post-excerpt" set:html={post.excerpt.rendered} />
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="section">
    <div class="section-header"><h2 class="section-title">Get in contact</h2></div>
    <div class="contact-block">
      <p>Feel free to reach out if you are interested in my work, have any questions, or just want to say hi!</p>
      <p>You can reach me at <a href="mailto:info.mvdvl@gmail.com">info.mvdvl@gmail.com</a>.</p>
    </div>
  </section>
</Layout>

<Fragment slot="body-end">
<script is:inline type="module">
import * as THREE from 'three';
import { RGBELoader } from 'three/addons/loaders/RGBELoader.js';

// ── Project data ──────────────────────────────────────────────────────────────
const PROJECTS = [
  {
    title: 'Python Auto-Rigger',
    meta:  'Three.js · Python (PyMel, Waitress, Watchdog)',
    desc:  'A web-based automatic rigging tool for remote motion-capture sessions, built as a graduation internship project at Het Nieuwe Kader.',
    color: 0x6aa9ff,
    links: [
      { label: 'Video', href: 'https://youtu.be/zupK9LBxZwk', newTab: true  },
      { label: 'Blog',  href: 'https://danthelion-git.github.io/DanTheLion-Resume/PythonAutorigger.html', newTab: false },
    ],
  },
  {
    title: 'Azure Static Site',
    meta:  'Personal Project · Azure Cloud',
    desc:  'Resume/portfolio hosted on Azure Blob Storage as a static website, combined with serverless Azure Functions for backend logic.',
    color: 0x4fc3f7,
    links: [
      { label: 'Live', href: 'https://danielresumestorage.z6.web.core.windows.net/', newTab: true },
    ],
  },
  {
    title: 'Oosterschelde VR',
    meta:  '360° Interactive Video · Custom Hardware',
    desc:  'Immersive 360° underwater VR experience for the Oosterschelde nature reserve — shot, edited, and delivered end-to-end under strict hardware constraints.',
    color: 0x34d399,
    links: [
      { label: '(WIP) Video', href: 'https://youtu.be/VprojdpSWek', newTab: true  },
      { label: '(WIP) Blog',  href: 'https://danthelion-git.github.io/DanTheLion-Resume/Oosterschelde.html', newTab: false },
    ],
  },
  {
    title: 'VR Voyage Amsterdam',
    meta:  'Historical VR · Pipeline Automation · Render Cost',
    desc:  'Historical VR experience taking viewers to 17th-century Amsterdam, with automated pipeline tooling that cut render cost significantly.',
    color: 0xfbbf24,
    links: [
      { label: 'Video', href: 'https://youtu.be/OL2vQRpIjFM', newTab: true  },
      { label: 'Blog',  href: 'https://danthelion-git.github.io/DanTheLion-Resume/VRVoyage.html', newTab: false },
    ],
  },
  {
    title: 'Wired Workers Showroom',
    meta:  'Unity WebGL · 3D Animation · Performance',
    desc:  'Virtual showroom for collaborative robot solutions built in Unity WebGL with animated product demonstrations optimised for browser performance.',
    color: 0xf87171,
    links: [
      { label: 'Video', href: 'https://youtu.be/XgOcEGr6uVE', newTab: true },
    ],
  },
];

// ── DOM refs ──────────────────────────────────────────────────────────────────
const wrapper    = document.getElementById('podium-wrapper');
const canvas     = document.getElementById('podium-canvas');
const panel      = document.getElementById('proj-panel');
const panelTitle = document.getElementById('proj-title');
const panelMeta  = document.getElementById('proj-meta');
const panelDesc  = document.getElementById('proj-desc');
const panelLinks = document.getElementById('proj-links');
const closeBtn   = document.getElementById('proj-close');
if (!wrapper || !canvas) throw new Error('Podium elements not found');

const W = () => wrapper.offsetWidth;
const H = () => wrapper.offsetHeight;

// ── Renderer ──────────────────────────────────────────────────────────────────
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
renderer.setSize(W(), H());
renderer.toneMapping        = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.2;
renderer.outputColorSpace   = THREE.SRGBColorSpace;
renderer.shadowMap.enabled  = false;   // no shadow-casting lights with HDRI-only

// ── Scene & camera ────────────────────────────────────────────────────────────
const scene  = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(50, W() / H(), 0.1, 50);

const LOOK_TARGET = new THREE.Vector3(0, 0.07, 0);
const CAM_DIST    = 3.0;
const CAM_ELEV    = 20 * (Math.PI / 180);
const EASE_RATE   = 0.10;

const camH = LOOK_TARGET.y + CAM_DIST * Math.sin(CAM_ELEV);
const camR = CAM_DIST * Math.cos(CAM_ELEV);

let targetTheta  = 0;
let currentTheta = 0;

function updateCamera() {
  currentTheta += (targetTheta - currentTheta) * EASE_RATE;
  camera.position.set(
    Math.sin(currentTheta) * camR,
    camH,
    Math.cos(currentTheta) * camR,
  );
  camera.lookAt(LOOK_TARGET);
}
updateCamera();

// ── HDRI environment lighting ─────────────────────────────────────────────────
// Tries /hdri/scene.hdr first; falls back to a Polyhaven studio HDR from CDN;
// final fallback: plain ambient light so the scene always renders.
const pmrem  = new THREE.PMREMGenerator(renderer);
pmrem.compileEquirectangularShader();

function applyEnv(tex) {
  scene.environment = pmrem.fromEquirectangular(tex).texture;
  tex.dispose();
  pmrem.dispose();
}

const loader = new RGBELoader();
loader.load(
  '/hdri/scene.hdr',
  applyEnv,
  undefined,
  () => loader.load(
    'https://dl.polyhaven.org/file/ph-assets/HDRIs/hdr/1k/studio_small_08_1k.hdr',
    applyEnv,
    undefined,
    () => { scene.add(new THREE.AmbientLight(0xffffff, 1.4)); pmrem.dispose(); },
  ),
);

// ── Display platform — single white flat cylinder ─────────────────────────────
const plateMat = new THREE.MeshStandardMaterial({
  color:       0xffffff,
  metalness:   0.05,
  roughness:   0.22,
  envMapIntensity: 1.0,
});
const plateMesh = new THREE.Mesh(new THREE.CylinderGeometry(0.88, 0.88, 0.04, 64), plateMat);
plateMesh.position.y = 0.02;
scene.add(plateMesh);

// ── Project cubes (group is static — no rotation) ─────────────────────────────
const podiumGroup  = new THREE.Group();
const PODIUM_TOP_Y = 0.04 + 0.115 / 2;   // disc top + half-cube height
const ARC_R        = 0.27;
const N            = PROJECTS.length;
const cubes        = [];

for (let i = 0; i < N; i++) {
  const angle = N > 1 ? (i / (N - 1) - 0.5) * (Math.PI * 0.80) : 0;
  const cube  = new THREE.Mesh(
    new THREE.BoxGeometry(0.115, 0.115, 0.115),
    new THREE.MeshStandardMaterial({
      color:             PROJECTS[i].color,
      metalness:         0.25,
      roughness:         0.35,
      emissive:          new THREE.Color(PROJECTS[i].color),
      emissiveIntensity: 0.0,
      envMapIntensity:   1.0,
    }),
  );
  cube.position.set(Math.sin(angle) * ARC_R, PODIUM_TOP_Y, Math.cos(angle) * ARC_R);
  cube.userData.projectIndex = i;
  podiumGroup.add(cube);
  cubes.push(cube);
}
scene.add(podiumGroup);

// ── Selection ─────────────────────────────────────────────────────────────────
let selectedIndex = -1;

function selectProject(idx) {
  if (selectedIndex >= 0 && selectedIndex < cubes.length) {
    cubes[selectedIndex].material.emissiveIntensity = 0.0;
    cubes[selectedIndex].scale.setScalar(1.0);
  }
  selectedIndex = idx;

  if (idx < 0) {
    panel.classList.remove('open');
    panel.setAttribute('aria-hidden', 'true');
    return;
  }

  cubes[idx].material.emissiveIntensity = 0.40;
  cubes[idx].scale.setScalar(1.22);

  const p      = PROJECTS[idx];
  panelTitle.textContent = p.title;
  panelMeta.textContent  = p.meta;
  panelDesc.textContent  = p.desc;
  panelLinks.innerHTML   = '';
  p.links.forEach(({ label, href, newTab }) => {
    const a       = document.createElement('a');
    a.className   = 'button-ghost';
    a.href        = href;
    a.textContent = label;
    if (newTab) { a.target = '_blank'; a.rel = 'noopener'; }
    panelLinks.appendChild(a);
  });

  panel.classList.add('open');
  panel.setAttribute('aria-hidden', 'false');
}

closeBtn.addEventListener('click', () => selectProject(-1));

// ── Full 360° drag-to-orbit ───────────────────────────────────────────────────
let isDragging = false, lastX = 0, totalDrag = 0;

canvas.addEventListener('pointerdown', (e) => {
  isDragging = true;
  lastX = e.clientX;
  totalDrag = 0;
  canvas.setPointerCapture(e.pointerId);
});

window.addEventListener('pointermove', (e) => {
  if (!isDragging) return;
  const dx   = e.clientX - lastX;
  lastX       = e.clientX;
  totalDrag  += Math.abs(dx);
  // Full-width drag = one full 360° rotation
  targetTheta -= (dx / W()) * (Math.PI * 2);
});

window.addEventListener('pointerup', (e) => {
  if (!isDragging) return;
  isDragging = false;
  if (totalDrag < 6) handleClick(e);
});

const raycaster = new THREE.Raycaster();
const pointer   = new THREE.Vector2();

function handleClick(e) {
  const rect  = canvas.getBoundingClientRect();
  pointer.x   =  ((e.clientX - rect.left) / rect.width ) * 2 - 1;
  pointer.y   = -((e.clientY - rect.top ) / rect.height) * 2 + 1;
  raycaster.setFromCamera(pointer, camera);
  const hits = raycaster.intersectObjects(cubes);
  if (hits.length > 0) {
    const idx = hits[0].object.userData.projectIndex;
    selectProject(idx === selectedIndex ? -1 : idx);
  } else {
    selectProject(-1);
  }
}

new ResizeObserver(() => {
  renderer.setSize(W(), H());
  camera.aspect = W() / H();
  camera.updateProjectionMatrix();
}).observe(wrapper);

(function animate() {
  requestAnimationFrame(animate);
  updateCamera();
  renderer.render(scene, camera);
})();
</script>

</Fragment>
