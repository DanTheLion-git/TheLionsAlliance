---
import Layout from "../layouts/ResumeLayout.astro";
import { getPosts, type WPPost } from "../lib/wp";
import { decodeHTML } from "../lib/html";
const posts: WPPost[] = await getPosts(3);
---

<Layout title="Daniël van Leeuwen — CV" theme="light">

  <!-- ── CV Identity ─────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-main">
        <p class="hero-tagline">Curriculum Vitae · Creative Technologist</p>
        <h1 class="hero-title">Daniël <span class="hero-highlight">van Leeuwen</span></h1>
        <p class="hero-text">
          Creative developer based in the Netherlands with 2+ years of professional experience in real-time 
          3D and immersive technologies. Skilled in Blender, motion capture pipelines, VR production, greenscreen 
          workflows, and custom hardware development, with hands-on experience in Unreal Engine and Unity.
        </p>
        <div class="hero-actions">
          <a href="https://www.youtube.com/@DanTheLionVFX" class="btn-social btn-yt" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="12" viewBox="0 0 16 12" fill="currentColor" aria-hidden="true"><path d="M15.7 1.9A2 2 0 0 0 14.3.5C13 .2 8 .2 8 .2S3 .2 1.7.5A2 2 0 0 0 .3 1.9C0 3.2 0 6 0 6s0 2.8.3 4.1A2 2 0 0 0 1.7 11.5C3 11.8 8 11.8 8 11.8s5 0 6.3-.3a2 2 0 0 0 1.4-1.4C16 8.8 16 6 16 6s0-2.8-.3-4.1zM6.4 8.6V3.4L10.6 6 6.4 8.6z"/></svg>
            YouTube
          </a>
          <a href="https://sketchfab.com/superwortel" class="btn-social btn-sf" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            Sketchfab
          </a>
          <a href="https://daanvanleeuwen.itch.io" class="btn-social btn-itch" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3.1 1C1.7 1.8 0 3.9 0 6v1.2c0 1.5 1.4 2.9 2.7 2.9 1.5 0 2.8-1.3 2.8-2.8 0 1.5 1.3 2.8 2.7 2.8 1.5 0 2.8-1.3 2.8-2.8 0 1.5 1.3 2.8 2.8 2.8 1.5 0 2.8-1.3 2.8-2.8 0 1.5 1.3 2.8 2.8 2.8C21.6 10 23 8.6 23 7.1V6c0-2.1-1.7-4.2-3.1-5C17.5 0 5.6 0 3.1 1zm5 10c-.5.2-1.4.7-2.1 1.4C5 13.4 5 14.1 5 18v4l1 .6c1.2.7 3.7 1.4 6 1.4s4.8-.8 6-1.4l1-.6v-4c0-3.9-.1-4.6-1.1-5.6-.7-.7-1.6-1.2-2.1-1.4-.3-.1-1.4-.2-4-.2s-3.6.1-3.9.2zm.6 3.1c.3-.1 1.4-.2 3.3-.2s3 .1 3.3.2c.8.3 1.6 1 1.6 1.6v2.3c0 .3-.1.4-.8.4H7.8c-.7 0-.8 0-.8-.4v-2.3c0-.6.8-1.3 1.6-1.6z"/></svg>
            Itch.io
          </a>
        </div>
        <p class="hero-subnote">info.mvdvl@gmail.com &nbsp;·&nbsp; The Netherlands</p>
      </div>
      <aside class="hero-side">
        <div class="pill">Currently exploring</div>
        <ul class="hero-side-list">
          <li>• Touch Screen Table</li>
          <li>• Robotic Horse</li>
          <li>• Brief aan Jan</li>
          <li>• Amsterdam 2.0</li>
          <li>• Puzzle Lantern</li>
          <li>• Home Streaming</li>
          <li>• Wedding Camera Rentals</li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- ── Work Experience ─────────────────────────────────────── -->
  <section id="experience" class="section">
    <div class="section-header">
      <h2 class="section-title">Work Experience</h2>
      <p class="section-subtitle">A short overview of my professional background</p>
    </div>
    <div class="contact-block">
      <ul class="post-list">
        <li class="post-card">
          <h3 class="card-title">Software Developer</h3>
          <p class="post-meta">Pebble · Feb 2026 – present</p>
          <p class="post-excerpt">Worked with ASP.NET, C#, and Azure to enable data access at ASML by developing a web application that streamlined setting up retention policies for data storage.</p>
        </li>
        <li class="post-card">
          <h3 class="card-title">3D Animation and Video Developer</h3>
          <p class="post-meta">Enversed Studios · Dec 2023 – Feb 2026</p>
          <p class="post-excerpt">Created 3D animations and videos using Blender and After Effects. Used Xsens motion capture and Reallusion to create realistic character animations. Performed on-site recordings at client locations.</p>
        </li>
      </ul>
      <details style="margin-top:0.75rem">
        <summary class="section-link" style="cursor:pointer">Show more experience</summary>
        <ul class="post-list" style="margin-top:0.9rem">
          <li class="post-card">
            <h3 class="card-title">Graduation Internship</h3>
            <p class="post-meta">Het Nieuwe Kader · Jan 2023 – Jul 2023</p>
            <p class="post-excerpt">Created a custom web-based automatic rigging tool for remote motion-capture sessions.</p>
          </li>
          <li class="post-card">
            <h3 class="card-title">Intern Product Specialist</h3>
            <p class="post-meta">Movella / Xsens · Mar 2022 – Aug 2022</p>
            <p class="post-excerpt">Documentation, customer demos and technical support for the Xsens MVN Animate platform.</p>
          </li>
          <li class="post-card">
            <h3 class="card-title">Junior VR Developer</h3>
            <p class="post-meta">Wired Workers · Jul 2020 – Aug 2021</p>
            <p class="post-excerpt">WebGL digital showroom for collaborative robot arms; 3D models and animations.</p>
          </li>
        </ul>
      </details>
    </div>
  </section>

  <!-- ── Client Projects (Carousel) ───────────────────────── -->
  <section id="work" class="section">
    <div class="section-header">
      <h2 class="section-title">Projects</h2>
      <p class="section-subtitle">Click the arrows or swipe to browse</p>
    </div>
    <div class="carousel-wrap">
      <button class="carousel-btn carousel-prev" aria-label="Previous project">&#8249;</button>
      <div class="carousel-track" id="carousel-track"></div>
      <button class="carousel-btn carousel-next" aria-label="Next project">&#8250;</button>
    </div>
    <div class="carousel-dots" id="carousel-dots"></div>
  </section>

  <!-- ── Skills & Tools ─────────────────────────────────────── -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Skills &amp; Tools</h2>
    </div>
    <div class="contact-block">
      <p class="post-meta" style="margin-bottom:0.4rem"><strong>3D &amp; Animation</strong></p>
      <p class="post-excerpt" style="margin-bottom:0.85rem">Blender · After Effects · Xsens Motion Capture · Reallusion · Unity · Unreal Engine</p>
      <p class="post-meta" style="margin-bottom:0.4rem"><strong>Development</strong></p>
      <p class="post-excerpt" style="margin-bottom:0.85rem">Three.js · WebGL · Python · C# · ASP.NET · Azure · TypeScript · HTML / CSS / JavaScript</p>
      <p class="post-meta" style="margin-bottom:0.4rem"><strong>Production &amp; Hardware</strong></p>
      <p class="post-excerpt">Video editing · 360° VR filming · On-site recording · Custom electronics · Arduino · Raspberry Pi</p>
    </div>
  </section>

  <!-- ── Latest Blogposts ────────────────────────────────────── -->
  <section id="writing" class="section">
    <div class="section-header">
      <h2 class="section-title">Latest Blogposts</h2>
      <a href="/blog/" class="section-link">View all posts →</a>
    </div>
    {posts.length === 0 && <p>No posts found yet.</p>}
    {posts.length > 0 && (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-card">
            <a href={`/blog/${post.slug}/`} class="post-title">{decodeHTML(post.title.rendered)}</a>
            <p class="post-meta">
              <time datetime={post.date}>
                {new Date(post.date).toLocaleDateString("en-GB", { year: "numeric", month: "short", day: "2-digit" })}
              </time>
            </p>
            <p class="post-excerpt" set:html={post.excerpt.rendered} />
          </li>
        ))}
      </ul>
    )}
  </section>

  <!-- ── Contact ─────────────────────────────────────────────── -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Get in contact</h2>
    </div>
    <div class="contact-block">
      <p>Feel free to reach out if you are interested in my work, have any questions, or just want to say hi!</p>
      <p>You can reach me at <a href="mailto:info.mvdvl@gmail.com">info.mvdvl@gmail.com</a>.</p>
    </div>
  </section>

</Layout>

<Fragment slot="body-end">
<script is:inline>
(function () {

// ═══════════════════════════════════════════════════════════════════
// PROJECT CONFIG — edit your project cards here
// ═══════════════════════════════════════════════════════════════════
// title   : project name
// meta    : subtitle / tech stack shown below the title
// image   : static image path, e.g. '/images/projects/myproject.jpg'
//           → set to null if you use youtube instead
// youtube : any YouTube URL (youtu.be/ID  or  watch?v=ID)
//           → set to null if you use image instead
//           → youtube takes priority when both are set
// desc    : description paragraph on the card
// link    : optional button  →  { label: 'Visit', href: 'https://...' }
//           set to null for no button
// ═══════════════════════════════════════════════════════════════════
var PROJECTS = [
  {
    title:   'Amsterdam Rederij',
    meta:    'Interactive WebGL · 3D Experience',
    image:   null,
    youtube: 'https://youtu.be/sfveQ_2cajM?si=3svZRFPYH1WRLxwk',
    desc:    'Interactive 3D web experience created for Amsterdam Rederij.',
    link:    { label: 'Watch Playlist', href: 'https://www.youtube.com/playlist?list=PLh7EOh1n0_buBScK2L7dAFNsPW2xpWRCT' },
  },
  {
    title:   'Martens Beton',
    meta:    'Product Visualisation · Blender 3D',
    image:   null,
    youtube: 'https://youtu.be/AVFDtIFl_yc',
    desc:    'Animated video to showcase the new product line of Martens Beton, created using Blender and After Effects.',
    link:    null,
  },
  {
    title:   'Werken bij Schiphol',
    meta:    'On-site recording · Greenscreen',
    image:   'https://www.werkopschiphol.nl/App_SkinMaster/images/og-image.jpg',
    youtube: null,
    desc:    'Interactive recruitment experience for Werken bij Schiphol.',
    link:    null,
  },
  {
    title:   'Lucardi',
    meta:    'Product Showcase · Blender 3D',
    image:   'https://i9.ytimg.com/vi_webp/bbm4KqhNv1E/mq2.webp?sqp=CJi9wM4G-oaymwEoCMACELQB8quKqQMcGADwAQH4AbYIgAK4CIoCDAgAEAEYZSBlKGUwDw==&rs=AOn4CLAg_IDQMhBgqI6J9mGK5QTTxAtOGg',
    youtube: null,
    desc:    'A 3D product showcase for Lucardi, created using Blender',
    link:    'https://youtube.com/shorts/bbm4KqhNv1E',
  },
  {
    title:   'Oosterschelde',
    meta:    '360° Interactive Video · Custom Hardware',
    image:   null,
    youtube: 'https://youtu.be/VprojdpSWek',
    desc:    'Immersive 360° underwater VR experience for the Oosterschelde nature reserve.',
    link:    null,
  },
  {
    title:   'Garbage Gary',
    meta:    'Game Development · Unity',
    image:   null,
    youtube: 'https://youtu.be/Nn0hLqFrPOk',
    desc:    'A game project created with other students for the Oyfo museum using Unity 3D, my responsibility was product lead and engine development.',
    link:    { label: 'Play Game', href: 'https://daanvanleeuwen.itch.io/viktor-vuilnis' },
  },
  {
    title:   'Meijel Museum',
    meta:    'Interactive Museum Experience',
    image:   'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQcy-9dPnImDKqCkmfymIThv7mLA-2zTguw_g&s',
    youtube: null,
    desc:    'Interactive digital experience developed for Meijel Museum.',
    link:    null,
  },
];

// ── Helpers ─────────────────────────────────────────────────────────
function toEmbedUrl(url) {
  var m = url.match(/(?:youtu\.be\/|[?&]v=)([\w-]{11})/);
  return m ? 'https://www.youtube.com/embed/' + m[1] + '?rel=0' : url;
}

// ── Build cards ─────────────────────────────────────────────────────
var track  = document.getElementById('carousel-track');
var dotsEl = document.getElementById('carousel-dots');
if (!track) return;

PROJECTS.forEach(function (p) {
  var card = document.createElement('div');
  card.className = 'project-card';

  var heroHtml;
  if (p.youtube) {
    heroHtml = '<div class="project-card-hero"><iframe src="' + toEmbedUrl(p.youtube)
      + '" loading="lazy" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture"'
      + ' allowfullscreen></iframe></div>';
  } else if (p.image) {
    heroHtml = '<div class="project-card-hero"><img src="' + p.image
      + '" alt="' + p.title + '" loading="lazy"></div>';
  } else {
    heroHtml = '<div class="project-card-hero project-card-hero--empty"><span>' + p.title + '</span></div>';
  }

  var linkHtml = p.link
    ? '<a href="' + p.link.href + '" class="button-ghost proj-card-btn" target="_blank" rel="noopener noreferrer">'
      + p.link.label + '</a>'
    : '';

  card.innerHTML = heroHtml
    + '<div class="project-card-body">'
    + '<h3 class="project-card-title">' + p.title + '</h3>'
    + '<p class="project-card-meta">' + p.meta + '</p>'
    + '<p class="project-card-desc">' + p.desc + '</p>'
    + linkHtml + '</div>';

  track.appendChild(card);
});

// ── Carousel navigation ──────────────────────────────────────────────
function cpv() { return window.innerWidth >= 680 ? 2 : 1; }

function cardStride() {
  var first = track.firstElementChild;
  if (!first) return 300;
  return first.offsetWidth + (parseFloat(getComputedStyle(track).gap) || 24);
}

function buildDots() {
  dotsEl.innerHTML = '';
  var n = Math.ceil(PROJECTS.length / cpv());
  for (var i = 0; i < n; i++) {
    (function (idx) {
      var d = document.createElement('button');
      d.className = 'carousel-dot';
      d.setAttribute('aria-label', 'Slide ' + (idx + 1));
      d.addEventListener('click', function () { goTo(idx); });
      dotsEl.appendChild(d);
    })(i);
  }
  updateDots();
}

function updateDots() {
  var stride = cardStride();
  var slide  = stride > 0 ? Math.round(track.scrollLeft / (stride * cpv())) : 0;
  dotsEl.querySelectorAll('.carousel-dot')
    .forEach(function (d, i) { d.classList.toggle('active', i === slide); });
}

function goTo(slideIdx) {
  track.scrollTo({ left: slideIdx * cardStride() * cpv(), behavior: 'smooth' });
}

document.querySelector('.carousel-prev')
  .addEventListener('click', function () { track.scrollBy({ left: -cardStride(), behavior: 'smooth' }); });
document.querySelector('.carousel-next')
  .addEventListener('click', function () { track.scrollBy({ left:  cardStride(), behavior: 'smooth' }); });

track.addEventListener('scroll', updateDots, { passive: true });
window.addEventListener('resize', buildDots);
buildDots();

})();
</script>
</Fragment>