---
// Protected admin dashboard — /admin/
// The JS below redirects unauthenticated visitors to /admin/login before the page renders.
// To add more services, copy a block in the `services` array below.

const services = [
  {
    name: "Jellyfin",
    description: "Movies & series",
    href: "http://192.168.178.58:8096",
    icon: "🎬",
    color: "teal",
  },
  {
    name: "Lions Alliance Streamer",
    description: "Custom stream server",
    href: "http://192.168.178.58:5000",
    icon: "📡",
    color: "purple",
  },
  {
    name: "Audiobookshelf",
    description: "Audiobooks",
    href: "http://192.168.178.58:13378",
    icon: "📚",
    color: "orange",
  },
  {
    name: "Finance",
    description: "Financial overview",
    href: "http://192.168.178.58:8085",
    icon: "💰",
    color: "blue",
  },
  // Add more:
  // { name: "Pi-hole", description: "DNS / Ads", href: "http://192.168.178.58:8081", icon: "🛡️", color: "red" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin — The Lions Alliance</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <!-- Auth check — runs before paint to avoid flash -->
    <script is:inline>
      var ADMIN_HASH = '644e75c04a697ad3d274d8bb244071904247b04a6be027ec1464aa3fbb4364dd';
      if (sessionStorage.getItem('tla-admin') !== ADMIN_HASH) {
        location.replace('/admin/login');
      }
    </script>

    <main class="wrap">
      <header class="header">
        <div class="header-top">
          <div>
            <div class="brand">
              <span class="brand-lion">&#9650;</span>
              The Lions Alliance
            </div>
            <h1>Home Services</h1>
            <p class="sub">Local network — requires home network or VPN MeshNet</p>
          </div>
          <button id="logout-btn" class="logout-btn" title="Log out">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Log out
          </button>
        </div>
      </header>

      <section class="grid" aria-label="Services">
        {services.map((s) => (
          <a class={`card ${s.color}`} href={s.href} target="_blank" rel="noopener">
            <div class="cardTop">
              <div class="icon" aria-hidden="true">{s.icon}</div>
              <div class="titleBlock">
                <div class="name">{s.name}</div>
                <div class="desc">{s.description}</div>
              </div>
            </div>
            <div class="cta">
              Open <span aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </section>

      <footer class="footer">
        <a href="/">← Back to main site</a>
      </footer>
    </main>

    <script is:inline>
      document.getElementById('logout-btn').addEventListener('click', function() {
        sessionStorage.removeItem('tla-admin');
        location.replace('/admin/login');
      });
    </script>
  </body>
</html>

<style>
  :root {
    --bg: #0b0f17;
    --panel: rgba(255, 255, 255, 0.06);
    --panelHover: rgba(255, 255, 255, 0.10);
    --text: rgba(255, 255, 255, 0.92);
    --muted: rgba(255, 255, 255, 0.55);
    --border: rgba(255, 255, 255, 0.12);
    --gold: #c9a84c;
    --radius: 18px;
    --shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    --max: 1050px;
    font-family: 'Inter', system-ui, sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { min-height: 100%; }

  body {
    color: var(--text);
    background:
      radial-gradient(1200px 700px at 20% 0%,  rgba(99,102,241,.22), transparent 55%),
      radial-gradient(900px  700px at 80% 20%,  rgba(20,184,166,.18), transparent 60%),
      radial-gradient(900px  700px at 50% 100%, rgba(168,85,247,.15), transparent 55%),
      var(--bg);
  }

  .wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 42px 18px 36px;
  }

  .header { margin-bottom: 28px; }
  .header-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: .45rem;
    font-size: .82rem;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: .06em;
    text-transform: uppercase;
    margin-bottom: .6rem;
  }
  .brand-lion { font-size: .6rem; color: var(--gold); transform: rotate(-30deg); display: inline-block; }

  h1 {
    font-size: clamp(24px, 4vw, 38px);
    line-height: 1.1;
    letter-spacing: -.02em;
  }
  .sub {
    margin-top: .4rem;
    color: var(--muted);
    font-size: .85rem;
  }

  .logout-btn {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    padding: .4rem .9rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-size: .82rem;
    font-family: inherit;
    cursor: pointer;
    transition: border-color 140ms, color 140ms;
    white-space: nowrap;
    margin-top: .3rem;
  }
  .logout-btn:hover { border-color: rgba(255,255,255,.35); color: var(--text); }

  .grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 18px;
    padding: 18px;
    border-radius: var(--radius);
    background: var(--panel);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    text-decoration: none;
    color: inherit;
    transition: transform 140ms ease, background 140ms ease, border-color 140ms ease;
    position: relative;
    overflow: hidden;
    min-height: 122px;
  }
  .card:hover { transform: translateY(-2px); background: var(--panelHover); border-color: rgba(255,255,255,.22); }

  .cardTop { display: flex; align-items: center; gap: 12px; }
  .icon {
    width: 46px; height: 46px;
    border-radius: 14px;
    display: grid; place-items: center;
    font-size: 22px;
    background: rgba(255,255,255,.10);
    border: 1px solid rgba(255,255,255,.14);
    flex-shrink: 0;
  }
  .name { font-weight: 650; font-size: 17px; letter-spacing: -.01em; }
  .desc { color: var(--muted); font-size: 13px; margin-top: 2px; }
  .cta { font-weight: 600; font-size: 13px; color: rgba(255,255,255,.82); display: inline-flex; gap: 8px; align-items: center; }

  .footer { margin-top: 28px; }
  .footer a { font-size: .85rem; color: var(--muted); text-decoration: none; transition: color 140ms; }
  .footer a:hover { color: var(--text); }

  /* Accent glows */
  .card.teal::before, .card.purple::before, .card.blue::before,
  .card.red::before,  .card.orange::before, .card.green::before {
    content: "";
    position: absolute;
    inset: -30% -30% auto -30%;
    height: 120%;
    filter: blur(30px);
    opacity: .32;
    pointer-events: none;
  }
  .card.teal::before   { background: radial-gradient(circle at 30% 30%, rgba(20,184,166,.9),  transparent 60%); }
  .card.purple::before { background: radial-gradient(circle at 30% 30%, rgba(168,85,247,.9),  transparent 60%); }
  .card.blue::before   { background: radial-gradient(circle at 30% 30%, rgba(59,130,246,.9),  transparent 60%); }
  .card.red::before    { background: radial-gradient(circle at 30% 30%, rgba(239,68,68,.9),   transparent 60%); }
  .card.orange::before { background: radial-gradient(circle at 30% 30%, rgba(249,115,22,.9),  transparent 60%); }
  .card.green::before  { background: radial-gradient(circle at 30% 30%, rgba(34,197,94,.9),   transparent 60%); }
</style>
