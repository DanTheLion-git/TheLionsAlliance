---
// No server-side logic
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lions Planner — Projects</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #1d2327;
      min-height: 100vh;
      color: #f0f0f1;
    }
    /* ── Header ─────────────────────────────────────────────── */
    .header {
      background: rgba(9,11,8,0.88);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid #3c434a;
      color: #f0f0f1;
      padding: 0 2rem;
      height: 58px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header-title {
      font-size: 1.05rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: .5rem;
      letter-spacing: .02em;
      color: #f0f0f1;
    }
    .header-actions { display: flex; gap: .75rem; }
    /* ── Buttons ─────────────────────────────────────────────── */
    .btn {
      padding: .45rem 1rem;
      border-radius: 8px;
      font-family: inherit;
      font-size: .875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all .15s;
      border: none;
    }
    .btn-primary { background: #2271b1; color: #f0f0f1; }
    .btn-primary:hover { background: #1a5a8c; }
    .btn-primary:disabled { opacity: .55; cursor: not-allowed; }
    .btn-ghost { background: rgba(255,255,255,0.08); color: #f0f0f1; border: 1px solid #3c434a; }
    .btn-ghost:hover { background: rgba(255,255,255,0.14); }
    .btn-danger { background: rgba(220,38,38,0.15); color: #fc8181; border: 1px solid rgba(220,38,38,0.3); }
    .btn-danger:hover { background: rgba(220,38,38,0.25); }
    .btn-secondary { background: #3c434a; color: #f0f0f1; }
    .btn-secondary:hover { background: #4a535b; }
    /* ── Main layout ─────────────────────────────────────────── */
    .main { max-width: 1200px; margin: 0 auto; padding: 2rem; }
    .page-heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 2rem;
    }
    .page-heading h2 { font-size: 1.5rem; font-weight: 700; color: #f0f0f1; }
    .page-heading p { color: #a7aaad; font-size: .875rem; margin-top: .25rem; }
    /* ── Projects grid ───────────────────────────────────────── */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
      gap: 1.25rem;
    }
    /* ── Project card ────────────────────────────────────────── */
    .project-card {
      background: #2c3338;
      border-radius: 14px;
      border: 1px solid #3c434a;
      border-left: 5px solid #2271b1;
      padding: 1.4rem 1.4rem 1.1rem;
      cursor: pointer;
      transition: transform .15s, box-shadow .15s, background .15s;
      position: relative;
      overflow: hidden;
    }
    .project-card:hover {
      background: #323a40;
      box-shadow: 0 8px 32px rgba(0,0,0,0.35);
      transform: translateY(-2px);
    }
    .project-card:hover .delete-btn { opacity: 1; }
    .delete-btn {
      position: absolute;
      top: .9rem; right: .9rem;
      background: rgba(220,38,38,0.15);
      border: 1px solid rgba(220,38,38,0.25);
      border-radius: 7px;
      color: #fc8181;
      width: 28px; height: 28px;
      font-size: 1rem;
      cursor: pointer;
      opacity: 0;
      transition: opacity .2s, background .15s;
      display: flex; align-items: center; justify-content: center;
      line-height: 1;
    }
    .delete-btn:hover { background: rgba(220,38,38,0.3); }
    .project-color-bar {
      position: absolute;
      top: 0; left: 0;
      width: 5px; height: 100%;
      border-radius: 14px 0 0 14px;
    }
    .project-name {
      font-size: 1.1rem;
      font-weight: 700;
      color: #f0f0f1;
      margin-bottom: .35rem;
      padding-right: 2.2rem;
      line-height: 1.3;
    }
    .project-desc {
      font-size: .825rem;
      color: #a7aaad;
      margin-bottom: 1.1rem;
      min-height: 1.2rem;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.55;
    }
    .task-badges {
      display: flex;
      flex-wrap: wrap;
      gap: .4rem;
    }
    .badge {
      font-size: .7rem;
      font-weight: 600;
      padding: 3px 9px;
      border-radius: 9999px;
      display: flex;
      align-items: center;
      gap: 3px;
    }
    .badge-backlog    { background: rgba(167,170,173,0.12); color: #a7aaad; border: 1px solid rgba(167,170,173,0.2); }
    .badge-todo       { background: rgba(95,168,211,0.15);  color: #5fa8d3; border: 1px solid rgba(95,168,211,0.25); }
    .badge-inprogress { background: rgba(212,163,47,0.15);  color: #d4a32f; border: 1px solid rgba(212,163,47,0.25); }
    .badge-done       { background: rgba(29,185,84,0.15);   color: #1db954; border: 1px solid rgba(29,185,84,0.25); }
    /* ── Empty / loading states ──────────────────────────────── */
    .empty-state {
      grid-column: 1 / -1;
      text-align: center;
      padding: 5rem 2rem;
      color: #a7aaad;
    }
    .empty-state .icon { font-size: 3rem; margin-bottom: 1rem; opacity: .6; }
    .empty-state h3 { font-size: 1.15rem; font-weight: 600; color: #f0f0f1; margin-bottom: .5rem; }
    .empty-state p { font-size: .875rem; }
    .loading { text-align: center; padding: 3rem; color: #a7aaad; font-size: .875rem; }
    /* ── Modal ───────────────────────────────────────────────── */
    .overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.65);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      padding: 1rem;
    }
    .overlay.show { display: flex; }
    .modal {
      background: #2c3338;
      border: 1px solid #3c434a;
      border-radius: 16px;
      padding: 2rem;
      width: 100%;
      max-width: 480px;
      box-shadow: 0 30px 60px rgba(0,0,0,0.5);
    }
    .modal h3 { font-size: 1.2rem; font-weight: 700; margin-bottom: 1.5rem; color: #f0f0f1; }
    .field { margin-bottom: 1.25rem; }
    label { display: block; font-size: .875rem; font-weight: 500; color: #a7aaad; margin-bottom: .4rem; }
    input[type="text"], textarea {
      width: 100%; padding: .65rem .9rem;
      background: #1d2327;
      border: 1.5px solid #3c434a; border-radius: 10px;
      color: #f0f0f1;
      font-family: inherit; font-size: .9rem;
      transition: border-color .2s; resize: vertical;
    }
    input[type="text"]::placeholder, textarea::placeholder { color: #a7aaad; }
    input[type="text"]:focus, textarea:focus { outline: none; border-color: #5fa8d3; }
    textarea { min-height: 80px; }
    .color-swatches { display: flex; gap: .6rem; flex-wrap: wrap; }
    .swatch {
      width: 32px; height: 32px;
      border-radius: 50%;
      cursor: pointer;
      border: 3px solid transparent;
      transition: transform .15s, border-color .15s;
      outline: 2px solid transparent;
      outline-offset: 2px;
    }
    .swatch:hover { transform: scale(1.15); }
    .swatch.selected { outline-color: #f0f0f1; transform: scale(1.1); }
    .modal-actions { display: flex; gap: .75rem; justify-content: flex-end; margin-top: 1.5rem; }
    /* ── Toast ───────────────────────────────────────────────── */
    .toast {
      position: fixed; bottom: 1.5rem; right: 1.5rem;
      background: #2c3338; color: #f0f0f1;
      border: 1px solid #3c434a;
      padding: .75rem 1.25rem;
      border-radius: 10px;
      font-size: .875rem; font-weight: 500;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
      opacity: 0; transform: translateY(10px);
      transition: all .3s;
      z-index: 2000; pointer-events: none;
    }
    .toast.show { opacity: 1; transform: translateY(0); }
    .toast.error { background: rgba(220,38,38,0.9); border-color: #dc2626; }

    /* ── Project avatar ───────────────────────────────────── */
    .project-avatar {
      width: 42px; height: 42px;
      border-radius: 11px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.15rem; font-weight: 800;
      margin-bottom: 1rem; flex-shrink: 0;
      letter-spacing: -.02em;
    }
    /* ── Project total count ─────────────────────────────── */
    .project-meta {
      display: flex; align-items: center; gap: .5rem;
      font-size: .75rem; color: #a7aaad;
      margin-bottom: .8rem;
    }
    .project-meta-dot { width: 4px; height: 4px; border-radius: 50%; background: #3c434a; }
    /* ── Progress bar ─────────────────────────────────────── */
    .project-progress { margin-bottom: .9rem; }
    .progress-track {
      height: 4px; background: rgba(255,255,255,0.08);
      border-radius: 9999px; overflow: hidden; margin-bottom: .3rem;
    }
    .progress-fill {
      height: 100%; border-radius: 9999px;
      background: linear-gradient(90deg, #2271b1, #5fa8d3);
      transition: width .5s ease; min-width: 0;
    }
    .progress-fill.complete { background: linear-gradient(90deg, #1db954, #22c55e); }
    .progress-label { font-size: .7rem; color: #a7aaad; font-weight: 500; }
    /* ── Project card header ─────────────────────────────── */
    .project-card-header {
      display: flex; align-items: flex-start;
      justify-content: space-between; margin-bottom: -.1rem;
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="header-title">🦁 Lions Planner</div>
    <div class="header-actions">
      <button class="btn btn-primary" id="new-project-btn">+ New Project</button>
      <button class="btn btn-ghost" id="signout-btn">Sign out</button>
    </div>
  </header>

  <main class="main">
    <div class="page-heading">
      <div>
        <h2>Projects</h2>
        <p id="projects-count">Loading…</p>
      </div>
    </div>
    <div class="projects-grid" id="projects-grid">
      <div class="loading">Loading projects…</div>
    </div>
  </main>

  <!-- New Project Modal -->
  <div class="overlay" id="modal-overlay">
    <div class="modal">
      <h3>New Project</h3>
      <form id="project-form">
        <div class="field">
          <label for="proj-name">Name <span style="color:#dc2626">*</span></label>
          <input type="text" id="proj-name" placeholder="My awesome project" required />
        </div>
        <div class="field">
          <label for="proj-desc">Description</label>
          <textarea id="proj-desc" placeholder="What's this project about?"></textarea>
        </div>
        <div class="field">
          <label>Color</label>
          <div class="color-swatches" id="color-swatches">
            <div class="swatch selected" data-color="#6366f1" style="background:#6366f1"></div>
            <div class="swatch" data-color="#e11d48" style="background:#e11d48"></div>
            <div class="swatch" data-color="#10b981" style="background:#10b981"></div>
            <div class="swatch" data-color="#f59e0b" style="background:#f59e0b"></div>
            <div class="swatch" data-color="#8b5cf6" style="background:#8b5cf6"></div>
            <div class="swatch" data-color="#0ea5e9" style="background:#0ea5e9"></div>
          </div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" id="modal-cancel">Cancel</button>
          <button type="submit" class="btn btn-primary" id="modal-submit">Create Project</button>
        </div>
      </form>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    import { supabase } from '../../lib/supabase.ts'

    type Project = {
      id: string
      name: string
      description: string
      color: string
      created_at: string
    }

    type TaskCount = {
      backlog: number
      todo: number
      in_progress: number
      done: number
    }

    let selectedColor = '#6366f1'

    async function init() {
      const { data: { session } } = await supabase.auth.getSession()
      if (!session) { window.location.replace('/planner/login'); return }
      await loadProjects()
      setupModal()
      setupSignOut()
    }

    async function loadProjects() {
      const grid = document.getElementById('projects-grid') as HTMLElement
      const countEl = document.getElementById('projects-count') as HTMLElement

      const { data: projects, error } = await supabase
        .from('projects')
        .select('*')
        .order('created_at', { ascending: true })

      if (error) {
        showToast('Failed to load projects', true)
        grid.innerHTML = '<div class="loading">Error loading projects.</div>'
        return
      }

      countEl.textContent = `${projects?.length ?? 0} project${(projects?.length ?? 0) !== 1 ? 's' : ''}`

      if (!projects || projects.length === 0) {
        grid.innerHTML = `
          <div class="empty-state">
            <div class="icon">📋</div>
            <h3>No projects yet</h3>
            <p>Create your first project to get started!</p>
          </div>`
        return
      }

      // Fetch all tasks for these projects
      const projectIds = projects.map((p: Project) => p.id)
      const { data: tasks } = await supabase
        .from('tasks')
        .select('project_id, status')
        .in('project_id', projectIds)

      // Build count map
      const countMap: Record<string, TaskCount> = {}
      for (const p of projects) {
        countMap[p.id] = { backlog: 0, todo: 0, in_progress: 0, done: 0 }
      }
      for (const t of (tasks ?? [])) {
        if (countMap[t.project_id]) {
          const s = t.status as keyof TaskCount
          if (s in countMap[t.project_id]) countMap[t.project_id][s]++
        }
      }

      grid.innerHTML = ''
      for (const project of projects as Project[]) {
        grid.appendChild(createProjectCard(project, countMap[project.id]))
      }
    }

    function createProjectCard(project: Project, counts: TaskCount): HTMLElement {
      const card = document.createElement('div')
      card.className = 'project-card'
      card.style.borderLeftColor = project.color
      card.dataset.id = project.id

      const total = counts.backlog + counts.todo + counts.in_progress + counts.done
      const donePercent = total > 0 ? Math.round((counts.done / total) * 100) : 0
      const initial = project.name.charAt(0).toUpperCase()
      // Muted version of project color for avatar bg (hex → rgba)
      const hex = project.color.replace('#', '')
      const r = parseInt(hex.slice(0,2),16)
      const g = parseInt(hex.slice(2,4),16)
      const b = parseInt(hex.slice(4,6),16)

      card.innerHTML = `
        <div class="project-card-header">
          <div class="project-avatar"
               style="background:rgba(${r},${g},${b},0.18);color:${project.color}">
            ${initial}
          </div>
          <button class="delete-btn" data-id="${project.id}" title="Delete project">×</button>
        </div>
        <div class="project-name">${escHtml(project.name)}</div>
        <div class="project-desc">${escHtml(project.description || 'No description')}</div>
        <div class="project-meta">
          <span>${total} task${total !== 1 ? 's' : ''}</span>
          ${total > 0 ? `<span class="project-meta-dot"></span><span>${donePercent}% done</span>` : ''}
        </div>
        ${total > 0 ? `
        <div class="project-progress">
          <div class="progress-track">
            <div class="progress-fill ${donePercent === 100 ? 'complete' : ''}" style="width:${donePercent}%"></div>
          </div>
        </div>` : ''}
        <div class="task-badges">
          ${counts.backlog > 0     ? `<span class="badge badge-backlog">○ ${counts.backlog}</span>` : ''}
          ${counts.todo > 0        ? `<span class="badge badge-todo">◎ ${counts.todo}</span>` : ''}
          ${counts.in_progress > 0 ? `<span class="badge badge-inprogress">◑ ${counts.in_progress}</span>` : ''}
          ${counts.done > 0        ? `<span class="badge badge-done">● ${counts.done}</span>` : ''}
          ${total === 0            ? `<span class="badge badge-backlog" style="opacity:.5">No tasks yet</span>` : ''}
        </div>`

      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement
        if (target.closest('.delete-btn')) return
        window.location.href = `/planner/board?id=${project.id}`
      })

      const deleteBtn = card.querySelector('.delete-btn') as HTMLButtonElement
      deleteBtn.addEventListener('click', (e) => {
        e.stopPropagation()
        deleteProject(project.id, project.name)
      })

      return card
    }

    async function deleteProject(id: string, name: string) {
      if (!confirm(`Delete project "${name}"? This will also delete all its tasks. This cannot be undone.`)) return
      const { error } = await supabase.from('projects').delete().eq('id', id)
      if (error) { showToast('Failed to delete project', true); return }
      showToast(`Project "${name}" deleted`)
      await loadProjects()
    }

    function setupModal() {
      const overlay = document.getElementById('modal-overlay') as HTMLElement
      const form = document.getElementById('project-form') as HTMLFormElement
      const cancelBtn = document.getElementById('modal-cancel') as HTMLButtonElement
      const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement
      const newBtn = document.getElementById('new-project-btn') as HTMLButtonElement
      const swatches = document.querySelectorAll('.swatch')

      newBtn.addEventListener('click', () => {
        form.reset()
        selectedColor = '#6366f1'
        swatches.forEach(s => s.classList.remove('selected'))
        swatches[0].classList.add('selected')
        overlay.classList.add('show')
        setTimeout(() => (document.getElementById('proj-name') as HTMLInputElement).focus(), 50)
      })

      cancelBtn.addEventListener('click', () => overlay.classList.remove('show'))
      overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('show') })

      swatches.forEach(swatch => {
        swatch.addEventListener('click', () => {
          swatches.forEach(s => s.classList.remove('selected'))
          swatch.classList.add('selected')
          selectedColor = (swatch as HTMLElement).dataset.color ?? '#6366f1'
        })
      })

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        submitBtn.disabled = true
        submitBtn.textContent = 'Creating…'

        const name = (document.getElementById('proj-name') as HTMLInputElement).value.trim()
        const description = (document.getElementById('proj-desc') as HTMLTextAreaElement).value.trim()

        const { error } = await supabase.from('projects').insert({ name, description, color: selectedColor })

        submitBtn.disabled = false
        submitBtn.textContent = 'Create Project'

        if (error) { showToast('Failed to create project', true); return }

        overlay.classList.remove('show')
        showToast(`Project "${name}" created!`)
        await loadProjects()
      })
    }

    function setupSignOut() {
      document.getElementById('signout-btn')?.addEventListener('click', async () => {
        await supabase.auth.signOut()
        window.location.replace('/planner/login')
      })
    }

    function escHtml(str: string): string {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
    }

    let toastTimer: ReturnType<typeof setTimeout>
    function showToast(msg: string, isError = false) {
      const toast = document.getElementById('toast') as HTMLElement
      toast.textContent = msg
      toast.className = 'toast show' + (isError ? ' error' : '')
      clearTimeout(toastTimer)
      toastTimer = setTimeout(() => toast.classList.remove('show'), 3000)
    }

    init()
  </script>
</body>
</html>
