---
import '../../styles/games.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Games — The Lions Alliance</title>
</head>
<body class="game-page">

  <header class="game-header">
    <a href="/" class="brand">🦁 The Lions Alliance</a>
    <nav><a href="/">← Home</a></nav>
  </header>

  <div class="game-content">
    <div style="text-align:center;margin-bottom:0.5rem;">
      <div class="g-title">🎮 Game Room</div>
      <p class="g-subtitle">Pick a game and let the fun begin</p>
    </div>

    <div class="games-grid">
      <a href="/games/hitster/" class="game-tile">
        <span class="icon">🎵</span>
        <span class="name">Hitster</span>
        <span class="badge">Play</span>
      </a>

      <a href="/games/30-seconds/" class="game-tile">
        <span class="icon">⏱</span>
        <span class="name">30 Seconds</span>
        <span class="badge">Play</span>
      </a>

      <a href="/games/charades/" class="game-tile">
        <span class="icon">🎭</span>
        <span class="name">Charades</span>
        <span class="badge">Play</span>
      </a>
    </div>
  </div>

</body>
</html>
