---
import '../../../styles/global.css';
import '../../../styles/games.css';
const title = "Hitster — Callback";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <script is:inline>
    (function () {
      var stored = localStorage.getItem('lions-theme');
      var theme = stored ? stored : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.className = 'theme-' + theme;
    })();
  </script>
</head>
<body class="game-page" style="align-items:center;justify-content:center;">
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">The Lions Alliance</a>
      <nav class="nav">
        <a href="/games/">Games</a>
        <a href="/resume/">Resume</a>
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle colour scheme" title="Toggle light / dark mode">
          <svg class="theme-icon theme-icon--sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1"  x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1"  y1="12" x2="3"  y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22"  y1="19.78" x2="5.64"  y2="18.36"/><line x1="18.36" y1="5.64"  x2="19.78" y2="4.22"/>
          </svg>
          <svg class="theme-icon theme-icon--moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>
      </nav>
    </div>
  </header>
  <div class="g-card" style="max-width:400px;text-align:center;margin:2rem auto;">
    <p class="g-subtitle" id="status">Connecting to Spotify…</p>
  </div>

  <script>
    import { exchangeCode } from '../../../lib/spotify';

    async function handleCallback() {
      const statusEl = document.getElementById('status')!;
      const params   = new URLSearchParams(window.location.search);
      const code     = params.get('code');
      const error    = params.get('error');

      if (error) {
        statusEl.textContent = `Spotify declined access: ${error}`;
        return;
      }

      if (!code) {
        statusEl.textContent = 'No code received from Spotify.';
        return;
      }

      try {
        await exchangeCode(code);
        statusEl.textContent = '✅ Connected! Redirecting…';
        const returnTo = sessionStorage.getItem('spotify_return_to') ?? '/games/hitster/';
        sessionStorage.removeItem('spotify_return_to');
        setTimeout(() => { window.location.href = returnTo; }, 800);
      } catch (err: unknown) {
        const msg = err instanceof Error ? err.message : String(err);
        statusEl.textContent = `❌ Auth failed: ${msg}`;
      }
    }

    handleCallback();
  </script>
  <footer class="site-footer">
    <p>&copy; 2025 The Lions Alliance</p>
  </footer>

  <script is:inline>
    (function () {
      var btn  = document.getElementById('theme-toggle');
      var html = document.documentElement;
      if (!btn) return;
      btn.addEventListener('click', function () {
        var next = html.classList.contains('theme-light') ? 'dark' : 'light';
        html.className = 'theme-' + next;
        localStorage.setItem('lions-theme', next);
      });
    })();
  </script>
</body>
</html>
