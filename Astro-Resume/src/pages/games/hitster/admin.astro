---
import '../../../styles/global.css';
import '../../../styles/games.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hitster Admin — Card Generator</title>

  <style>
    /* ── Print layout ───────────────────────────────────────────────────── */
    @media print {
      .no-print { display: none !important; }

      @page {
        size: A4 portrait;
        margin: 10mm;
      }

      .print-page {
        display: block !important;
        page-break-after: always;
        break-after: page;
      }

      /*
       * 3 × 4 = 12 cards per A4 page.
       * A4 printable area (10mm margins): 190mm × 277mm
       *   card width  = (190 - 2×3) / 3 = 61.33mm
       *   card height = (277 - 3×3) / 4 = 67mm
       * Explicit sizes ensure both front & back pages use the identical grid.
       */
      .cards-grid {
        display: grid !important;
        grid-template-columns: repeat(3, 61.33mm);
        grid-template-rows: repeat(4, 67mm);
        gap: 3mm;
      }

      .print-card {
        width: 61.33mm;
        height: 67mm;
        border: 0.35mm solid #c8c8c8;
        border-radius: 1.5mm;
        background: #ffffff;
        color: #000000;
        overflow: hidden;
        break-inside: avoid;
        box-sizing: border-box;
      }

      /* ── QR front card ── */
      .qr-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3mm;
        gap: 1mm;
      }
      .qr-card .card-brand {
        font-size: 6pt;
        font-weight: 900;
        letter-spacing: 2px;
        color: #555;
        text-transform: uppercase;
      }
      .qr-card img { width: 82%; height: auto; }

      /* ── Song info back card ── */
      .info-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        padding: 5mm 3mm;
        text-align: center;
      }
      .info-card .info-artist {
        font-size: 8pt;
        font-weight: 400;
        color: #000;
        line-height: 1.3;
        width: 100%;
      }
      .info-card .info-year {
        font-size: 72pt;
        font-weight: 900;
        color: #000;
        line-height: 1;
      }
      .info-card .info-song {
        font-size: 8pt;
        font-weight: 700;
        color: #000;
        line-height: 1.3;
        width: 100%;
      }
    }

    /* ── Screen-only preview ────────────────────────────────────────────── */
    @media screen {
      .print-only { display: none; }

      .cards-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(90px, 120px));
        gap: 0.5rem;
        justify-content: center;
      }

      .print-card {
        border: 1px solid #ccc;
        border-radius: 4px;
        aspect-ratio: 61 / 67;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0.4rem;
        background: #fff;
        color: #000;
        font-size: 0.65rem;
        overflow: hidden;
      }

      .qr-card { gap: 0.2rem; }
      .qr-card .card-brand { font-size: 0.48rem; font-weight: 900; letter-spacing: 1px; color: #555; }
      .qr-card img { width: 74%; height: auto; }

      .info-card {
        justify-content: space-between;
        padding: 0.45rem 0.3rem;
        text-align: center;
      }
      .info-card .info-artist { font-size: 0.55rem; color: #000; }
      .info-card .info-year   { font-size: 1.5rem; font-weight: 900; color: #000; line-height: 1; }
      .info-card .info-song   { font-size: 0.55rem; font-weight: 700; color: #000; }
    }

    /* ── Admin-specific screen styles ───────────────────────────────────── */
    .track-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.6rem 0.75rem;
      border-radius: var(--g-radius-sm);
      background: var(--g-surface);
      border: 1px solid var(--g-border);
      cursor: pointer;
      transition: border-color 0.15s;
    }

    .track-row:hover { border-color: var(--g-accent); }
    .track-row.selected { border-color: var(--g-green); }

    .track-row input[type="checkbox"] {
      accent-color: var(--g-green);
      width: 1rem;
      height: 1rem;
      flex-shrink: 0;
    }

    .track-thumb {
      width: 40px;
      height: 40px;
      border-radius: 4px;
      object-fit: cover;
      flex-shrink: 0;
      background: var(--g-surface2);
    }

    .track-info { flex: 1; min-width: 0; }
    .track-name { font-weight: 600; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .track-meta { font-size: 0.75rem; color: var(--g-muted); }

    .track-year {
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--g-accent2);
      flex-shrink: 0;
    }

    .print-preview-section {
      background: var(--g-surface);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius);
      padding: 1rem;
    }

    .print-preview-section h3 {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--g-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.75rem;
    }

    .spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid var(--g-border);
      border-top-color: var(--g-accent);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      vertical-align: middle;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Playlist picker grid ───────────────────────────────────────────── */
    .playlist-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 0.75rem;
      width: 100%;
    }
    .playlist-tile {
      background: var(--g-surface);
      border: 1px solid var(--g-border);
      border-radius: var(--g-radius-sm);
      cursor: pointer;
      overflow: hidden;
      transition: border-color 150ms, transform 150ms;
      display: flex;
      flex-direction: column;
      text-align: left;
      padding: 0;
    }
    .playlist-tile:hover {
      border-color: var(--g-accent2);
      transform: translateY(-2px);
    }
    .playlist-tile img {
      width: 100%;
      height: 0;
      padding-bottom: 100%; /* forces perfect 1:1 square */
      object-fit: cover;
      display: block;
      background: var(--g-surface2);
    }
    .playlist-tile .pl-art-placeholder {
      width: 100%;
      aspect-ratio: 1 / 1;
      background: var(--g-surface2);
      font-size: 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .playlist-tile-info  { padding: 0.5rem 0.6rem; }
    .playlist-tile-name  {
      font-size: 0.82rem; font-weight: 700;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      color: var(--g-text);
    }
    .playlist-tile-count { font-size: 0.7rem; color: var(--g-muted); margin-top: 0.15rem; }
    .pl-private { opacity: 0.5; cursor: default; }
    .pl-private:hover { border-color: var(--g-border); transform: none; }
  </style>
</head>

<body class="game-page">

  <header class="site-header no-print">
    <div class="container">
      <a href="/" class="logo">The Lions Alliance</a>
      <nav class="nav">
        <a href="/games/">Games</a>
        <a href="/resume/">Resume</a>
        <button id="btn-logout" class="g-btn outline small hidden" style="width:auto;font-size:0.8rem;">Disconnect</button>
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle colour scheme" title="Toggle light / dark mode">
          <svg class="theme-icon theme-icon--sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1"  x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1"  y1="12" x2="3"  y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22"  y1="19.78" x2="5.64"  y2="18.36"/><line x1="18.36" y1="5.64"  x2="19.78" y2="4.22"/>
          </svg>
          <svg class="theme-icon theme-icon--moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>
      </nav>
    </div>
  </header>

  <!-- ══ NOT AUTHENTICATED ════════════════════════════════════════════════ -->
  <div id="screen-unauthed" class="game-content no-print hidden">
    <div style="text-align:center;">
      <div class="hitster-logo">ADMIN</div>
      <p class="g-subtitle" style="margin-top:0.5rem;">Card Generator</p>
    </div>
    <div class="g-card" style="text-align:center;display:flex;flex-direction:column;gap:1rem;align-items:center;">
      <p style="font-size:0.9rem;color:var(--g-muted);">You need to connect Spotify first.</p>
      <a href="/games/hitster/" class="g-btn green" style="max-width:260px;">← Go to Hitster</a>
    </div>
  </div>

  <!-- ══ MAIN ADMIN UI ════════════════════════════════════════════════════ -->
  <div id="screen-admin" class="game-content no-print hidden" style="gap:1.25rem;">

    <!-- Title -->
    <div style="text-align:center;width:100%;">
      <div class="hitster-logo" style="font-size:1.8rem;">ADMIN</div>
      <p class="g-subtitle">Card Generator</p>
    </div>

    <!-- Playlist picker (shown on load) -->
    <div id="playlist-section" style="width:100%;display:flex;flex-direction:column;gap:1rem;">

      <!-- CSV Import panel — primary method (always works) -->
      <div class="g-card" style="gap:0.75rem;display:flex;flex-direction:column;">
        <div class="g-label" style="font-size:0.9rem;">📋 Import from CSV <span style="background:var(--g-accent);color:#fff;font-size:0.65rem;padding:0.1em 0.4em;border-radius:3px;margin-left:0.4rem;">RECOMMENDED</span></div>
        <p style="font-size:0.82rem;color:var(--g-muted);margin:0;line-height:1.7;">
          1. Go to <a href="https://exportify.net" target="_blank" rel="noopener" style="color:var(--g-accent2);">exportify.net</a> — log in with Spotify, click <strong>Export</strong> next to your Hitster playlist.<br>
          2. Open the downloaded <code style="background:var(--g-surface2);padding:0.1em 0.3em;border-radius:3px;">.csv</code> file in a text editor or Excel → <strong>Select All → Copy</strong>.<br>
          3. Paste the contents into the field below and click <strong>Load Tracks from CSV</strong>.
        </p>
        <textarea id="csv-input" rows="5"
          placeholder="Paste Exportify CSV here (Spotify URI, Track Name, Artist Name(s), Album Release Date…)"
          style="width:100%;padding:0.7rem;background:var(--g-bg);border:1px solid var(--g-border);border-radius:var(--g-radius-sm);color:var(--g-text);font-size:0.78rem;font-family:monospace;resize:vertical;box-sizing:border-box;"></textarea>
        <div id="csv-error" class="g-alert error hidden"></div>
        <button id="btn-parse-csv" class="g-btn green">📋 Load Tracks from CSV</button>
      </div>

      <!-- Divider -->
      <div style="display:flex;align-items:center;gap:0.75rem;color:var(--g-muted);font-size:0.8rem;">
        <hr style="flex:1;border:none;border-top:1px solid var(--g-border);" />
        or load directly from Spotify (may require reconnect)
        <hr style="flex:1;border:none;border-top:1px solid var(--g-border);" />
      </div>

      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
        <div class="g-label" style="font-size:0.9rem;">🎵 Your Playlists</div>
        <button id="btn-refresh-playlists" class="g-btn secondary small">&#8635; Refresh</button>
      </div>

      <!-- Loading / error states -->
      <div id="pl-loading" class="g-alert info hidden">
        <span class="spinner"></span>&nbsp; Loading your playlists…
      </div>
      <div id="pl-error" class="g-alert error hidden"></div>
      <button id="btn-reauth" class="g-btn outline small hidden" style="width:auto;align-self:flex-start;">
        &#128273; Reconnect Spotify (or <a href="https://www.spotify.com/account/apps" target="_blank" rel="noopener" style="color:inherit;text-decoration:underline;">remove app access first</a> if reconnect keeps failing)
      </button>

      <!-- Playlist grid -->
      <div id="playlist-grid" class="playlist-grid"></div>
    </div>

    <!-- Track list (hidden until a playlist is picked) -->
    <div id="track-section" class="hidden" style="width:100%;display:flex;flex-direction:column;gap:1rem;">

      <!-- Playlist header -->
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
        <div>
          <button id="btn-back-to-playlists" class="g-btn secondary small" style="width:auto;margin-bottom:0.4rem;">&#8592; All Playlists</button>
          <div id="playlist-name" class="g-label" style="font-size:0.9rem;color:var(--g-text);font-weight:700;"></div>
          <div id="playlist-meta" class="g-label"></div>
        </div>
        <div style="display:flex;gap:0.5rem;">
          <button id="btn-select-all"   class="g-btn secondary small">☑ All</button>
          <button id="btn-deselect-all" class="g-btn secondary small">☐ None</button>
        </div>
      </div>

      <!-- Track list -->
      <div id="track-list" style="display:flex;flex-direction:column;gap:0.4rem;max-height:50vh;overflow-y:auto;padding-right:0.25rem;"></div>

      <!-- Generate button -->
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <div id="selection-count" class="g-label" style="text-align:center;"></div>
        <button id="btn-generate" class="g-btn primary" style="font-size:1rem;">
          🃏 Generate Print Sheet
        </button>
      </div>

      <!-- Print progress -->
      <div id="gen-progress" class="g-alert info hidden">
        <span class="spinner"></span>
        <span id="gen-progress-text">Generating QR codes…</span>
      </div>
    </div>

    <!-- Print preview (screen only, shown after generation) -->
    <div id="preview-section" class="hidden" style="width:100%;display:flex;flex-direction:column;gap:1rem;">

      <div class="g-alert success">
        ✅ Cards ready! Review the preview below, then print.
      </div>

      <div class="g-card" style="gap:0.75rem;display:flex;flex-direction:column;">
        <p style="font-size:0.82rem;color:var(--g-muted);">
          🖨 Print <strong>double-sided, flip on long edge</strong>. Each sheet: front page (QR codes) then back page (year/song). Cut along the grey lines.
        </p>
        <button id="btn-print" class="g-btn green" style="font-size:1rem;">🖨 Print / Save as PDF</button>
        <button id="btn-back"  class="g-btn secondary">&#8592; Back to track list</button>
      </div>

      <!-- Dynamically populated by JS -->
      <div id="preview-content" style="width:100%;display:flex;flex-direction:column;gap:0.5rem;"></div>
    </div>

  </div><!-- /screen-admin -->


  <!-- ══ PRINT SHEET (screen: hidden; print: shown) ═══════════════════════ -->
  <div id="print-sheet" class="print-only" style="display:none;">
    <!-- Dynamically populated: alternating front/back pages, 12 cards each -->
  </div>


  <!-- ══ SCRIPTS ══════════════════════════════════════════════════════════ -->
  <script>
    import { isAuthenticated, getValidToken, logout, startSpotifyAuth, hasScope, grantedScopes } from '../../../lib/spotify';
    import QRCode from 'qrcode';

    // ── Types ──────────────────────────────────────────────────────────────
    interface Track {
      id:       string;
      uri:      string;
      name:     string;
      artist:   string;
      year:     number;
      albumArt: string;
    }

    // ── State ──────────────────────────────────────────────────────────────
    let allTracks: Track[]        = [];
    let selectedIds: Set<string>  = new Set();
    let generatedCards: { track: Track; qrDataUrl: string }[] = [];

    // ── DOM ────────────────────────────────────────────────────────────────
    const $  = (id: string) => document.getElementById(id)!;
    const show = (...ids: string[]) => ids.forEach(id => $( id).classList.remove('hidden'));
    const hide = (...ids: string[]) => ids.forEach(id => $( id).classList.add('hidden'));

    // ── Playlist parsing ───────────────────────────────────────────────────
    function parsePlaylistId(raw: string): string | null {
      const s = raw.trim();
      const uriMatch = s.match(/^spotify:playlist:([A-Za-z0-9]+)/);
      if (uriMatch) return uriMatch[1];
      const urlMatch = s.match(/open\.spotify\.com\/playlist\/([A-Za-z0-9]+)/);
      if (urlMatch) return urlMatch[1];
      if (/^[A-Za-z0-9]{22}$/.test(s)) return s;
      return null;
    }

    // ── Spotify API helpers ────────────────────────────────────────────────
    async function fetchPlaylistInfo(id: string, token: string) {
      const res = await fetch(`https://api.spotify.com/v1/playlists/${id}?fields=name,tracks.total`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) throw new Error(`Could not load playlist (${res.status}). Is it public?`);
      return res.json();
    }

    function parseTrackItems(items: Array<{ track: null | Record<string, unknown> }>): Track[] {
      const result: Track[] = [];
      for (const item of items) {
        const t = item.track;
        if (!t || !t.id) continue;
        const artists = t.artists as Array<{ name: string }>;
        const album   = t.album   as { release_date: string; images: Array<{ url: string }> };
        result.push({
          id:       t.id      as string,
          uri:      `spotify:track:${t.id}`,
          name:     t.name    as string,
          artist:   artists.map(a => a.name).join(', '),
          year:     new Date(album.release_date).getFullYear(),
          albumArt: album.images[0]?.url ?? '',
        });
      }
      return result;
    }

    function spotifyError(status: number, detail: string): Error {
      if (status === 403) {
        const scopes = grantedScopes();
        return new Error(
          `Spotify returned 403 (Forbidden) — your access token is missing playlist permissions.\n\n` +
          `Stored scopes: ${scopes}\n\n` +
          `Fix: Go to spotify.com/account/apps → find this app → click "Remove Access" → ` +
          `then click "Reconnect Spotify" below to re-authorise with the full playlist scope.`
        );
      }
      return new Error(`Spotify error ${status}${detail ? ': ' + detail : ''}. Please try again.`);
    }

    async function fetchAllTracks(playlistId: string, token: string): Promise<Track[]> {
      const tracks: Track[] = [];
      let url: string | null =
        `https://api.spotify.com/v1/playlists/${playlistId}/tracks?limit=100`;

      while (url) {
        const res = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
        if (!res.ok) {
          const body = await res.json().catch(() => ({})) as { error?: { message?: string } };
          throw spotifyError(res.status, body?.error?.message ?? '');
        }
        const data = await res.json();
        tracks.push(...parseTrackItems(data.items ?? []));
        url = data.next ?? null;
      }

      if (tracks.length === 0) {
        throw new Error(
          'Playlist loaded but contains 0 playable tracks. ' +
          'Make sure the playlist has regular Spotify songs (not local files or podcasts).'
        );
      }

      return tracks;
    }

    // ── Track list rendering ───────────────────────────────────────────────
    function renderTrackList(tracks: Track[]) {
      const list = $('track-list');
      list.innerHTML = '';

      tracks.forEach((t) => {
        const row = document.createElement('div');
        row.className = 'track-row selected';
        row.dataset.id = t.id;

        row.innerHTML = `
          <input type="checkbox" checked data-id="${t.id}" />
          ${t.albumArt
            ? `<img class="track-thumb" src="${t.albumArt}" alt="" />`
            : `<div class="track-thumb" style="display:flex;align-items:center;justify-content:center;font-size:1.2rem;">🎵</div>`
          }
          <div class="track-info">
            <div class="track-name">${escHtml(t.name)}</div>
            <div class="track-meta">${escHtml(t.artist)}</div>
          </div>
          <div class="track-year">${t.year}</div>
        `;

        const cb = row.querySelector('input')!;
        selectedIds.add(t.id);

        const toggle = () => {
          if (cb.checked) { selectedIds.add(t.id); row.classList.add('selected'); }
          else            { selectedIds.delete(t.id); row.classList.remove('selected'); }
          updateSelectionCount();
        };

        cb.addEventListener('change', toggle);
        row.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).tagName === 'INPUT') return;
          cb.checked = !cb.checked;
          toggle();
        });

        list.appendChild(row);
      });

      updateSelectionCount();
    }

    function updateSelectionCount() {
      $('selection-count').textContent = `${selectedIds.size} of ${allTracks.length} tracks selected`;
    }

    function escHtml(s: string): string {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── QR + card generation ───────────────────────────────────────────────
    async function generateCards(tracks: Track[]) {
      generatedCards = [];
      const total = tracks.length;
      const progText = $('gen-progress-text');

      for (let i = 0; i < total; i++) {
        const t = tracks[i];
        progText.textContent = `Generating QR codes… ${i + 1} / ${total}`;
        const qrDataUrl = await QRCode.toDataURL(t.uri, {
          width:        300,
          margin:       2,
          color:        { dark: '#000000', light: '#ffffff' },
          errorCorrectionLevel: 'M',
        });
        generatedCards.push({ track: t, qrDataUrl });
      }
    }

    // ── Build card HTML ────────────────────────────────────────────────────
    function buildFrontCard(c: { track: Track; qrDataUrl: string }): HTMLElement {
      const div = document.createElement('div');
      div.className = 'print-card qr-card';
      div.innerHTML = `
        <div class="card-brand">HITSTER</div>
        <img src="${c.qrDataUrl}" alt="QR" />
      `;
      return div;
    }

    function buildBackCard(c: { track: Track; qrDataUrl: string }): HTMLElement {
      const div = document.createElement('div');
      div.className = 'print-card info-card';
      const year = c.track.year || '?';
      div.innerHTML = `
        <div class="info-artist">${escHtml(c.track.artist)}</div>
        <div class="info-year">${year}</div>
        <div class="info-song">${escHtml(c.track.name)}</div>
      `;
      return div;
    }

    /**
     * For double-sided printing (flip on long edge), the back sheet needs its
     * columns mirrored per row so each card aligns with its matching front:
     *
     *  Front row:  [1][2][3]   Back row (mirrored):  [3][2][1]
     *
     * This way, after flipping the page on the long (vertical) edge, card
     * position [1] on the front aligns with position [1] on the back.
     */
    function mirrorRow<T>(arr: T[], cols: number): T[] {
      const result: T[] = [];
      for (let row = 0; row < Math.ceil(arr.length / cols); row++) {
        const slice = arr.slice(row * cols, (row + 1) * cols);
        result.push(...slice.reverse());
      }
      return result;
    }

    // ── CSV Import (Exportify) ─────────────────────────────────────────────
    function parseCSVRow(line: string): string[] {
      const result: string[] = [];
      let cur = '', inQ = false;
      for (let i = 0; i < line.length; i++) {
        const c = line[i];
        if (c === '"') {
          if (inQ && line[i + 1] === '"') { cur += '"'; i++; }
          else inQ = !inQ;
        } else if (c === ',' && !inQ) {
          result.push(cur); cur = '';
        } else cur += c;
      }
      result.push(cur);
      return result;
    }

    function parseCSVToTracks(raw: string): Track[] {
      const lines = raw.replace(/\r\n/g, '\n').replace(/\r/g, '\n')
        .split('\n').map(l => l.trim()).filter(l => l.length > 0);
      if (lines.length < 2) throw new Error('Need a header row and at least one track row.');

      const headers = parseCSVRow(lines[0]).map(h => h.replace(/^"|"$/g, '').toLowerCase());

      const idx = (kws: string[]) => headers.findIndex(h => kws.some(k => h.includes(k)));
      const uriIdx    = idx(['spotify uri', 'uri', 'track uri']);
      const nameIdx   = idx(['track name', 'name', 'title', 'song']);
      const artistIdx = idx(['artist name', 'artist']);
      const yearIdx   = idx(['release date', 'album date', 'year', 'date']);

      if (nameIdx   === -1) throw new Error('Could not find "Track Name" column. Is this an Exportify CSV?');
      if (artistIdx === -1) throw new Error('Could not find "Artist Name(s)" column.');

      const tracks: Track[] = [];
      for (let i = 1; i < lines.length; i++) {
        const cols   = parseCSVRow(lines[i]).map(c => c.replace(/^"|"$/g, '').trim());
        const name   = cols[nameIdx]   ?? '';
        const artist = cols[artistIdx] ?? '';
        if (!name && !artist) continue;

        const rawUri  = uriIdx   >= 0 ? cols[uriIdx]  ?? '' : '';
        const rawYear = yearIdx  >= 0 ? cols[yearIdx] ?? '' : '';

        let year = 0;
        const ym = rawYear.match(/(\d{4})/);
        if (ym) year = parseInt(ym[1]);

        const uriMatch = rawUri.match(/spotify:track:([A-Za-z0-9]+)/);
        const id  = uriMatch ? uriMatch[1] : `csv-${i}`;
        const uri = uriMatch ? rawUri : `spotify:search:${encodeURIComponent(name + ' ' + artist)}`;
        tracks.push({ id, uri, name, artist, year, albumArt: '' });
      }
      if (tracks.length === 0) throw new Error('No valid tracks found in the pasted data.');
      return tracks;
    }

    $('btn-parse-csv').addEventListener('click', () => {
      hide('csv-error');
      const raw = ($('csv-input') as HTMLTextAreaElement).value;
      if (!raw.trim()) {
        $('csv-error').textContent = 'Please paste CSV data first.';
        show('csv-error');
        return;
      }
      try {
        const tracks = parseCSVToTracks(raw);
        allTracks   = tracks;
        selectedIds = new Set(tracks.map(t => t.id));
        $('playlist-name').textContent = 'CSV Import';
        $('playlist-meta').textContent = `${tracks.length} tracks loaded`;
        renderTrackList(tracks);
        hide('playlist-section');
        show('track-section');
      } catch (err) {
        $('csv-error').textContent = err instanceof Error ? err.message : String(err);
        show('csv-error');
      }
    });

    // ── Fetch user's playlists ─────────────────────────────────────────────
    interface SpotifyPlaylist {
      id: string;
      name: string;
      public: boolean | null;
      images: Array<{ url: string }>;
      tracks: { href: string; total: number } | null;
    }

    async function fetchUserPlaylists(token: string): Promise<SpotifyPlaylist[]> {
      const playlists: SpotifyPlaylist[] = [];
      let url: string | null = 'https://api.spotify.com/v1/me/playlists?limit=50';
      while (url) {
        const res = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
        if (!res.ok) throw new Error(`Could not load your Spotify playlists (${res.status})`);
        const data = await res.json();
        playlists.push(...(data.items as SpotifyPlaylist[]).filter(p => p && p.id));
        url = data.next as string | null;
      }
      return playlists;
    }

    function renderPlaylistGrid(playlists: SpotifyPlaylist[]) {
      const grid = $('playlist-grid');
      grid.innerHTML = '';
      if (playlists.length === 0) {
        grid.innerHTML = '<p style="color:var(--g-muted);font-size:0.88rem;">No playlists found.</p>';
        return;
      }

      // Info banner
      const info = document.createElement('p');
      info.style.cssText = 'font-size:0.8rem;color:var(--g-muted);margin:0 0 0.5rem;grid-column:1/-1;';
      info.textContent = '🔓 Click a public playlist to load it. 🔒 Private playlists need to be made public in Spotify first.';
      grid.appendChild(info);

      for (const pl of playlists) {
        const isPublic = pl.public === true;
        const btn = document.createElement('button');
        btn.className = 'playlist-tile' + (isPublic ? '' : ' pl-private');
        const artUrl = pl.images?.[0]?.url;
        const artHtml = artUrl
          ? `<div style="width:100%;aspect-ratio:1/1;overflow:hidden;background:var(--g-surface2)"><img src="${artUrl}" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>`
          : `<div class="pl-art-placeholder">${isPublic ? '🎵' : '🔒'}</div>`;
        const total = pl.tracks?.total;
        btn.innerHTML = artHtml + `
          <div class="playlist-tile-info">
            <div class="playlist-tile-name" title="${pl.name}">${isPublic ? '' : '🔒 '}${pl.name}</div>
            <div class="playlist-tile-count">${total != null ? total + ' tracks' : isPublic ? 'public' : 'private'}</div>
          </div>`;

        if (isPublic) {
          btn.addEventListener('click', () => loadPlaylist(pl.id, pl.name, total ?? 0));
        } else {
          btn.title = 'Make this playlist public in Spotify to use it here';
          btn.addEventListener('click', () => {
            $('pl-error').textContent = `"${pl.name}" is private. In Spotify: open the playlist → ··· menu → Edit details → enable Public, then refresh.`;
            show('pl-error');
          });
        }
        grid.appendChild(btn);
      }
    }

    async function loadUserPlaylists() {
      hide('pl-error', 'btn-reauth');
      show('pl-loading');
      $('playlist-grid').innerHTML = '';
      try {
        const token = await getValidToken();
        if (!token) { logout(); location.href = '/games/hitster/'; return; }
        const playlists = await fetchUserPlaylists(token);
        renderPlaylistGrid(playlists);
      } catch (err) {
        $('pl-error').textContent = err instanceof Error ? err.message : String(err);
        show('pl-error');
      } finally {
        hide('pl-loading');
      }
    }

    async function loadPlaylist(playlistId: string, name: string, total: number) {
      hide('pl-error');
      $('playlist-name').textContent = name;
      $('playlist-meta').textContent = total ? `Loading ${total} tracks…` : 'Loading tracks…';
      hide('playlist-section');
      show('track-section');

      try {
        const token = await getValidToken();
        if (!token) { logout(); location.href = '/games/hitster/'; return; }

        const tracks = await fetchAllTracks(playlistId, token);
        allTracks = tracks;
        selectedIds = new Set(tracks.map(t => t.id));
        $('playlist-meta').textContent = `${tracks.length} tracks loaded`;
        renderTrackList(tracks);
      } catch (err) {
        $('playlist-meta').textContent = 'Failed to load tracks';
        hide('track-section');
        show('playlist-section');
        // Show full message (may contain newlines — use pre-wrap)
        const msg = err instanceof Error ? err.message : String(err);
        $('pl-error').style.whiteSpace = 'pre-wrap';
        $('pl-error').textContent = msg;
        show('pl-error', 'btn-reauth');
      }
    }

    // ── Select all / none ──────────────────────────────────────────────────
    $('btn-select-all').addEventListener('click', () => {
      document.querySelectorAll<HTMLInputElement>('#track-list input[type=checkbox]').forEach(cb => {
        cb.checked = true;
        const row = cb.closest('.track-row') as HTMLElement;
        row.classList.add('selected');
      });
      selectedIds = new Set(allTracks.map(t => t.id));
      updateSelectionCount();
    });

    $('btn-deselect-all').addEventListener('click', () => {
      document.querySelectorAll<HTMLInputElement>('#track-list input[type=checkbox]').forEach(cb => {
        cb.checked = false;
        (cb.closest('.track-row') as HTMLElement).classList.remove('selected');
      });
      selectedIds.clear();
      updateSelectionCount();
    });

    // ── Generate print sheet ───────────────────────────────────────────────
    $('btn-generate').addEventListener('click', async () => {
      const selected = allTracks.filter(t => selectedIds.has(t.id));
      if (selected.length === 0) {
        alert('Please select at least one track.');
        return;
      }

      hide('track-section');
      show('gen-progress');

      try {
        await generateCards(selected);

        const COLS     = 3;
        const PER_PAGE = 12; // 3 columns × 4 rows per A4

        // Clear dynamic containers
        const printSheet    = $('print-sheet');
        const previewContent = $('preview-content');
        printSheet.innerHTML    = '';
        previewContent.innerHTML = '';
        printSheet.style.display = '';

        const totalPages = Math.ceil(generatedCards.length / PER_PAGE);

        for (let p = 0; p < totalPages; p++) {
          const slice    = generatedCards.slice(p * PER_PAGE, (p + 1) * PER_PAGE);
          const mirrored = mirrorRow(slice, COLS);

          // ── Print pages ──────────────────────────────────────────────────
          // Front print page
          const frontPrintPage = document.createElement('div');
          frontPrintPage.className = 'print-page';
          const frontPrintGrid = document.createElement('div');
          frontPrintGrid.className = 'cards-grid';
          slice.forEach(c => frontPrintGrid.appendChild(buildFrontCard(c)));
          frontPrintPage.appendChild(frontPrintGrid);
          printSheet.appendChild(frontPrintPage);

          // Back print page
          const backPrintPage = document.createElement('div');
          backPrintPage.className = 'print-page';
          const backPrintGrid = document.createElement('div');
          backPrintGrid.className = 'cards-grid';
          mirrored.forEach(c => backPrintGrid.appendChild(buildBackCard(c)));
          backPrintPage.appendChild(backPrintGrid);
          printSheet.appendChild(backPrintPage);

          // ── Screen preview ───────────────────────────────────────────────
          const sheetLabel = document.createElement('h3');
          sheetLabel.style.cssText = 'font-size:0.85rem;font-weight:700;color:var(--g-muted);text-transform:uppercase;letter-spacing:0.06em;margin:1rem 0 0.5rem;';
          sheetLabel.textContent = `Sheet ${p + 1} of ${totalPages} — cards ${p * PER_PAGE + 1}–${Math.min((p + 1) * PER_PAGE, generatedCards.length)}`;
          previewContent.appendChild(sheetLabel);

          const frontLabel = document.createElement('p');
          frontLabel.style.cssText = 'font-size:0.75rem;color:var(--g-muted);margin:0 0 0.4rem;';
          frontLabel.textContent = '↑ Front (QR codes)';
          previewContent.appendChild(frontLabel);

          const frontPreviewGrid = document.createElement('div');
          frontPreviewGrid.className = 'cards-grid';
          slice.forEach(c => frontPreviewGrid.appendChild(buildFrontCard(c)));
          previewContent.appendChild(frontPreviewGrid);

          const backLabel = document.createElement('p');
          backLabel.style.cssText = 'font-size:0.75rem;color:var(--g-muted);margin:0.75rem 0 0.4rem;';
          backLabel.textContent = '↑ Back (artist / year / song) — columns mirrored for double-sided flip on long edge';
          previewContent.appendChild(backLabel);

          const backPreviewGrid = document.createElement('div');
          backPreviewGrid.className = 'cards-grid';
          mirrored.forEach(c => backPreviewGrid.appendChild(buildBackCard(c)));
          previewContent.appendChild(backPreviewGrid);
        }

        hide('gen-progress');
        show('preview-section');
      } catch (err) {
        hide('gen-progress');
        $('pl-error').textContent = err instanceof Error ? err.message : String(err);
        show('pl-error', 'track-section');
      }
    });

    $('btn-print').addEventListener('click', () => window.print());

    $('btn-back').addEventListener('click', () => {
      hide('preview-section');
      show('track-section');
    });

    $('btn-back-to-playlists').addEventListener('click', () => {
      hide('track-section', 'preview-section');
      show('playlist-section');
    });

    $('btn-refresh-playlists').addEventListener('click', () => loadUserPlaylists());

    // ── Logout ─────────────────────────────────────────────────────────────
    $('btn-logout').addEventListener('click', () => { logout(); location.href = '/games/hitster/'; });

    // Re-auth with full scope — store return-to so callback lands back on admin
    $('btn-reauth').addEventListener('click', () => {
      sessionStorage.setItem('spotify_return_to', '/games/hitster/admin/');
      logout();
      startSpotifyAuth();
    });

    // ── Init ───────────────────────────────────────────────────────────────
    if (isAuthenticated()) {
      show('screen-admin', 'btn-logout');
      loadUserPlaylists();
    } else {
      show('screen-unauthed');
    }
  </script>

  <footer class="site-footer">
    <p>&copy; 2025 The Lions Alliance</p>
  </footer>

  <script is:inline>
    (function () {
      var btn  = document.getElementById('theme-toggle');
      var html = document.documentElement;
      if (!btn) return;
      btn.addEventListener('click', function () {
        var next = html.classList.contains('theme-light') ? 'dark' : 'light';
        html.className = 'theme-' + next;
        localStorage.setItem('lions-theme', next);
      });
    })();
  </script>
</body>
</html>
