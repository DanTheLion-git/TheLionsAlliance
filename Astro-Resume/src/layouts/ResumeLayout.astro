---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** Pass "light" to activate the light colour-scheme overrides. */
  theme?: 'dark' | 'light';
}

const {
  title = "The Lions Alliance",
  description = "Bringing stories to life with technology and a touch of magic.",
  theme = 'dark',
} = Astro.props;
---

<html lang="en" class={`theme-${theme}`}>
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline type="importmap">
    {
      "imports": {
        "three":          "https://cdn.jsdelivr.net/npm/three@0.167.1/build/three.module.js",
        "three/addons/":  "https://cdn.jsdelivr.net/npm/three@0.167.1/examples/jsm/"
      }
    }
    </script>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <a href="/resume/" class="logo">The Lions Alliance</a>
        <nav class="nav">
          <a href="/resume/">Home</a>
          <a href="/blog/">Blog</a>
          <a href="/resume/">Resume</a>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} The Lions Alliance</p>
    </footer>

    <slot name="body-end" />
  </body>
</html>
