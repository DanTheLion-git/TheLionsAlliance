---
import "../styles/homepage.css";
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Lions Alliance &mdash; A Creative Experience Studio</title>
    <meta name="description" content="The Lions Alliance creates immersive, story-driven experiences that people remember. From intimate wedding moments to large-scale interactive worlds." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="tla-page">

    <!-- ── Navigation ─────────────────────────────────── -->
    <nav class="tla-nav" id="tla-nav">
      <div class="tla-nav__inner">
        <a href="/" class="tla-nav__logo">The Lions <span>Alliance</span></a>
        <ul class="tla-nav__links">
          <li><a href="#studio">Studio</a></li>
          <li><a href="#pillars">Our Work</a></li>
          <li><a href="#roadmap">Roadmap</a></li>
        </ul>
        <a href="/contact/" class="tla-nav__cta tla-nav__cta--gold">Contact</a>
        <button class="tla-nav__hamburger" id="tla-hamburger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
      <div class="tla-nav__mobile" id="tla-mobile-menu">
        <a href="#studio">Studio</a>
        <a href="#pillars">Our Work</a>
        <a href="#roadmap">Roadmap</a>
        <a href="/contact/">Contact</a>
      </div>
    </nav>

    <!-- ── Hero ───────────────────────────────────────── -->
    <section class="tla-hero" id="hero">
      <div class="tla-container">
        <div class="tla-fade">
          <p class="tla-hero__eyebrow">A Creative Experience Studio</p>
        </div>
        <h1 class="tla-hero__title tla-fade tla-d1">We craft experiences<br /><em>worth remembering.</em></h1>
        <p class="tla-hero__subtitle tla-fade tla-d2">From intimate wedding moments to interactive puzzle routes &mdash; we design story-driven experiences that stay with people long after they leave.</p>
        <div class="tla-hero__actions tla-fade tla-d3">
          <a href="#pillars" class="tla-btn tla-btn--primary">Explore our work</a>
          <a href="#roadmap" class="tla-btn tla-btn--outline">See our roadmap</a>
        </div>
        <div class="tla-hero__media tla-fade tla-d3">Showreel coming soon</div>
      </div>
    </section>

    <!-- ── Studio Statement ───────────────────────────── -->
    <section class="tla-studio" id="studio">
      <div class="tla-container">
        <div class="tla-studio__grid">
          <div class="tla-studio__text tla-fade">
            <span class="tla-overline">About the studio</span>
            <h2>Three pillars, one vision</h2>
            <p>The Lions Alliance is a creative experience studio. We believe the most memorable experiences share three qualities: they are personal, interactive, and beautifully crafted. Rather than doing everything, we focus on three connected pillars &mdash; each at a different stage of development.</p>
            <p style="margin-top:1rem;">The studio is built by <strong>Daniel van Leeuwen</strong> and <strong>Thirza Leeuwenhage</strong>.</p>
          </div>
          <div class="tla-studio__phases tla-fade tla-d2">
            <div class="tla-phase-item">
              <span class="tla-phase-item__num">01</span>
              <div>
                <p class="tla-phase-item__label">Live now</p>
                <p class="tla-phase-item__name">Moments</p>
              </div>
            </div>
            <div class="tla-phase-item">
              <span class="tla-phase-item__num">02</span>
              <div>
                <p class="tla-phase-item__label">In development</p>
                <p class="tla-phase-item__name">Experiences</p>
              </div>
            </div>
            <div class="tla-phase-item">
              <span class="tla-phase-item__num">03</span>
              <div>
                <p class="tla-phase-item__label">Future vision</p>
                <p class="tla-phase-item__name">Immersive Worlds</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Three Pillars ──────────────────────────────── -->
    <section class="tla-pillars" id="pillars">
      <div class="tla-container">
        <div class="tla-section-header tla-fade">
          <span class="tla-overline">What we&rsquo;re building</span>
          <h2>Three pillars of experience</h2>
          <div class="tla-divider"></div>
        </div>
        <div class="tla-pillars__grid">
          <!-- Pillar 1 -->
          <div class="tla-pillar-card tla-fade tla-d1">
            <div class="tla-pillar-card__head">
              <span class="tla-pillar-card__num">01</span>
              <span class="tla-badge tla-badge--live">Available Now</span>
            </div>
            <h3>Moments</h3>
            <p class="tla-pillar-card__tagline">Intimate &middot; Meaningful &middot; Shareable</p>
            <p class="tla-pillar-card__desc">The experiences that matter most &mdash; the kind that become stories people tell for years. Our first pillar focuses on personal, emotional, and beautifully crafted products.</p>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:auto;">
              <a href="https://weddingcambox.nl" class="tla-btn tla-btn--outline tla-btn--sm" target="_blank" rel="noopener">WeddingCamBox</a>
              <a href="https://shuttershare.nl" class="tla-btn tla-btn--outline tla-btn--sm" target="_blank" rel="noopener">ShutterShare</a>
              <span class="tla-btn tla-btn--outline tla-btn--sm" style="opacity:0.4;cursor:default;pointer-events:none;" aria-disabled="true">Murder Mystery — Coming Soon</span>
            </div>
          </div>
          <!-- Pillar 2 -->
          <div class="tla-pillar-card tla-fade tla-d2">
            <div class="tla-pillar-card__head">
              <span class="tla-pillar-card__num">02</span>
              <span class="tla-badge tla-badge--dev">In Development</span>
            </div>
            <h3>Experiences</h3>
            <p class="tla-pillar-card__tagline">Interactive &middot; Playful &middot; Story-Driven</p>
            <p class="tla-pillar-card__desc">Puzzle routes, interactive installations, and narrative games designed for real places. Built for the curious &mdash; people who want to explore and discover.</p>
            <a href="/puzzlequests/" class="tla-btn tla-btn--outline tla-btn--sm" style="margin-top:auto;">Puzzle Quests</a>
          </div>
          <!-- Pillar 3 -->
          <div class="tla-pillar-card tla-fade tla-d3">
            <div class="tla-pillar-card__head">
              <span class="tla-pillar-card__num">03</span>
              <span class="tla-badge tla-badge--future">Future Vision</span>
            </div>
            <h3>Immersive Worlds</h3>
            <p class="tla-pillar-card__tagline">Layered &middot; Spatial &middot; Unforgettable</p>
            <p class="tla-pillar-card__desc">Large-scale, location-based storytelling for cities, heritage sites, and historic routes. Experiences that transform a place into a living narrative.</p>
            <a href="/immersive/" class="tla-btn tla-btn--outline tla-btn--sm" style="margin-top:auto;">Immersive Worlds</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Featured Offering ──────────────────────────── -->
    <section class="tla-featured">
      <div class="tla-container">
        <div class="tla-featured__grid">
          <div class="tla-featured__visual tla-fade">
            <span class="tla-featured__visual-mark">WCB</span>
            <span class="tla-badge tla-badge--live">Live Now</span>
          </div>
          <div class="tla-featured__content tla-fade tla-d2">
            <span class="tla-overline">Moments &mdash; Phase 1</span>
            <h2>WeddingCamBox</h2>
            <p>Our first live offering. WeddingCamBox gives couples and guests a meaningful, personal way to capture their wedding day &mdash; 10 pocket cameras, beautifully simple.</p>
            <ul class="tla-featured__points">
              <li>Designed around the couple&rsquo;s story</li>
              <li>Simple for any guest</li>
              <li>Produces something worth keeping</li>
              <li>Available now</li>
            </ul>
            <div class="tla-featured__actions">
              <a href="https://weddingcambox.nl" class="tla-btn tla-btn--primary tla-btn--sm" target="_blank" rel="noopener">Explore WeddingCamBox</a>
              <a href="#contact" class="tla-btn tla-btn--outline tla-btn--sm">Get in touch</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Roadmap ────────────────────────────────────── -->
    <section class="tla-roadmap" id="roadmap">
      <div class="tla-container">
        <div class="tla-section-header tla-fade">
          <span class="tla-overline">Where we&rsquo;re headed</span>
          <h2>Our roadmap</h2>
          <div class="tla-divider"></div>
        </div>
        <div class="tla-timeline tla-fade tla-d1">

          <!-- Now – Mid 2026 -->
          <div class="tla-timeline__item tla-timeline__item--active">
            <div class="tla-timeline__node"></div>
            <div class="tla-timeline__head">
              <h3>Now &mdash; Mid 2026</h3>
              <span class="tla-badge tla-badge--live">Active</span>
            </div>
            <p class="tla-timeline__desc">WeddingCamBox peak season &middot; ShutterShare launch &middot; Greenscreen freelance &middot; Murder Mystery template development &middot; Puzzle Quest electronics prototyping</p>
          </div>

          <!-- Late 2026 -->
          <div class="tla-timeline__item tla-timeline__item--outlined">
            <div class="tla-timeline__node"></div>
            <div class="tla-timeline__head">
              <h3>Late 2026</h3>
              <span class="tla-badge tla-badge--dev">Upcoming</span>
            </div>
            <p class="tla-timeline__desc">Jan Truijen prototype at Medelo Museum &middot; First Puzzle Quest real-audience test &middot; Meijel map table concept design</p>
          </div>

          <!-- 2027 -->
          <div class="tla-timeline__item tla-timeline__item--outlined">
            <div class="tla-timeline__node"></div>
            <div class="tla-timeline__head">
              <h3>2027</h3>
              <span class="tla-badge tla-badge--future">Planning</span>
            </div>
            <p class="tla-timeline__desc">Puzzle Quest festival debut at Castlefest &amp; Elfia &middot; Magic Crystal production run &middot; Talking portrait pitched to other museums</p>
          </div>

          <!-- 2028+ -->
          <div class="tla-timeline__item tla-timeline__item--dashed">
            <div class="tla-timeline__node"></div>
            <div class="tla-timeline__head">
              <h3>2028 &amp; Beyond</h3>
              <span class="tla-badge tla-badge--future">Future Vision</span>
            </div>
            <p class="tla-timeline__desc">Scale Immersive Worlds &middot; City-scale narrative experiences &middot; Location-based storytelling at heritage sites and public spaces</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Values ─────────────────────────────────────── -->
    <section class="tla-values">
      <div class="tla-container">
        <div class="tla-section-header tla-fade">
          <span class="tla-overline">Our approach</span>
          <h2>Why The Lions Alliance</h2>
          <div class="tla-divider"></div>
        </div>
        <div class="tla-values__grid">
          <div class="tla-value-card tla-fade tla-d1">
            <h3>Story first</h3>
            <p>Every project begins with a narrative question. What story are we helping someone tell?</p>
          </div>
          <div class="tla-value-card tla-fade tla-d2">
            <h3>Physical meets digital</h3>
            <p>We blend what people can hold, scan, and share &mdash; bridging the tactile and the technological.</p>
          </div>
          <div class="tla-value-card tla-fade tla-d3">
            <h3>Built with intention</h3>
            <p>We build fewer things, more carefully. Every detail is considered, every decision deliberate.</p>
          </div>
          <div class="tla-value-card tla-fade tla-d1">
            <h3>Made to be remembered</h3>
            <p>Our measure of success is simple: did the experience stay with someone?</p>
          </div>
          <div class="tla-value-card tla-fade tla-d2">
            <h3>From intimate to immense</h3>
            <p>The same thinking scales from a wedding product to a city-wide narrative experience.</p>
          </div>
          <div class="tla-value-card tla-fade tla-d3">
            <h3>Long-term partners</h3>
            <p>We build lasting relationships with venues and organisations, not one-off transactions.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Contact ────────────────────────────────────── -->
    <section class="tla-contact" id="contact">
      <div class="tla-container">
        <span class="tla-overline tla-fade">Get in touch</span>
        <h2 class="tla-fade tla-d1">Let&rsquo;s build something<br />worth remembering</h2>
        <p class="tla-fade tla-d2">Whether you&rsquo;re planning a wedding, curious about our puzzle routes, or want to explore a partnership &mdash; we&rsquo;d love to hear from you.</p>
        <div class="tla-contact__actions tla-fade tla-d3">
          <a href="/contact/" class="tla-btn tla-btn--gold">Send us a message</a>
          <a href="https://weddingcambox.nl" class="tla-btn tla-btn--ghost" target="_blank" rel="noopener">Explore WeddingCamBox</a>
        </div>
        <p class="tla-contact__email tla-fade tla-d3"><a href="mailto:hello@thelionsalliance.com">hello@thelionsalliance.com</a></p>
      </div>
    </section>

    <!-- ── Footer ─────────────────────────────────────── -->
    <footer class="tla-footer">
      <div class="tla-container">
        <div class="tla-footer__inner">
          <div class="tla-footer__brand">
            <span class="tla-footer__logo">The Lions <span>Alliance</span></span>
            <span class="tla-footer__tagline">A Creative Experience Studio</span>
          </div>
          <nav class="tla-footer__links">
            <a href="#studio">Studio</a>
            <a href="#pillars">Our Work</a>
            <a href="#roadmap">Roadmap</a>
            <a href="/contact/">Contact</a>
            <a href="https://weddingcambox.nl" target="_blank" rel="noopener">WeddingCamBox</a>
            <a href="https://shuttershare.nl" target="_blank" rel="noopener">ShutterShare</a>
            <a href="/immersive/">Immersive Worlds</a>
            <a href="/puzzlequests/">Puzzle Quests</a>
          </nav>
        </div>
        <p class="tla-footer__copy">&copy; {year} The Lions Alliance. All rights reserved.</p>
      </div>
    </footer>

    <!-- ── Scripts ─────────────────────────────────────── -->
    <script>
      // Scroll-aware nav
      const nav = document.getElementById('tla-nav');
      window.addEventListener('scroll', () => {
        nav.classList.toggle('scrolled', window.scrollY > 40);
      }, { passive: true });

      // Hamburger toggle
      const hamburger = document.getElementById('tla-hamburger');
      const mobileMenu = document.getElementById('tla-mobile-menu');
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        mobileMenu.classList.toggle('open');
      });

      // Close mobile menu on link click
      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('active');
          mobileMenu.classList.remove('open');
        });
      });

      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          const target = document.querySelector(anchor.getAttribute('href'));
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });

      // IntersectionObserver for fade-in
      const faders = document.querySelectorAll('.tla-fade');
      const fadeObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('tla-visible');
            fadeObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      faders.forEach(el => fadeObserver.observe(el));
    </script>
  </body>
</html>
