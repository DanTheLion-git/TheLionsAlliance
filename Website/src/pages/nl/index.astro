---
import "../../styles/homepage.css";
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Lions Alliance &mdash; Een creatieve ervaringsstudio</title>
    <meta name="description" content="The Lions Alliance ontwerpt verhalende ervaringen die mensen bijblijven. Van intieme trouwmomenten tot interactieve puzzelroutes en grootschalige erfgoedinstallaties." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="en" href="https://thelionsalliance.com/" />
    <link rel="alternate" hreflang="nl" href="https://thelionsalliance.com/nl/" />
    <link rel="alternate" hreflang="x-default" href="https://thelionsalliance.com/" />
  </head>
  <body class="tla-page">

    <!-- ── Navigatie ──────────────────────────────────── -->
    <nav class="tla-nav" id="tla-nav">
      <div class="tla-nav__inner">
        <a href="/nl/" class="tla-nav__logo">The Lions <span>Alliance</span></a>
        <ul class="tla-nav__links">
          <li><a href="#studio">Studio</a></li>
          <li><a href="#pillars">Ons werk</a></li>
          <li><a href="#roadmap">Roadmap</a></li>
        </ul>
        <div class="tla-nav__actions">
          <a href="/" class="tla-nav__lang" hreflang="en" lang="en" title="View in English">EN</a>
          <a href="/contact/nl/" class="tla-nav__cta tla-nav__cta--gold">Contact</a>
        </div>
        <button class="tla-nav__hamburger" id="tla-hamburger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
      <div class="tla-nav__mobile" id="tla-mobile-menu">
        <a href="#studio">Studio</a>
        <a href="#pillars">Ons werk</a>
        <a href="#roadmap">Roadmap</a>
        <a href="/contact/nl/">Contact</a>
        <a href="/" hreflang="en" lang="en">View in English</a>
      </div>
    </nav>

    <!-- ── Hero ───────────────────────────────────────── -->
    <section class="tla-hero" id="hero">
      <div class="tla-container">
        <div class="tla-fade">
          <p class="tla-hero__eyebrow">Een creatieve ervaringsstudio</p>
        </div>
        <h1 class="tla-hero__title tla-fade tla-d1">Wij maken ervaringen<br /><em>die mensen bijblijven.</em></h1>
        <p class="tla-hero__subtitle tla-fade tla-d2">Van intieme trouwmomenten tot interactieve puzzelroutes &mdash; wij ontwerpen verhalende ervaringen die lang na afloop nog bij mensen blijven hangen.</p>
        <div class="tla-hero__actions tla-fade tla-d3">
          <a href="#pillars" class="tla-btn tla-btn--primary">Bekijk ons werk</a>
          <a href="#roadmap" class="tla-btn tla-btn--outline">Onze roadmap</a>
        </div>
        <div class="tla-hero__media tla-fade tla-d3">Showreel volgt binnenkort</div>
      </div>
    </section>

    <!-- ── Over de studio ─────────────────────────────── -->
    <section class="tla-studio" id="studio">
      <div class="tla-container">
        <div class="tla-studio__grid">
          <div class="tla-studio__text tla-fade">
            <span class="tla-overline">Over de studio</span>
            <h2>Drie pijlers, &eacute;&eacute;n visie</h2>
            <p>The Lions Alliance is een creatieve ervaringsstudio. Wij geloven dat de meest memorabele ervaringen drie eigenschappen delen: ze zijn persoonlijk, interactief en met aandacht gemaakt. In plaats van overal in te duiken, richten wij ons op drie verbonden pijlers &mdash; elk in een andere fase van ontwikkeling.</p>
            <p style="margin-top:1rem;">De studio wordt gerund door <strong>Daniel van Leeuwen</strong> en <strong>Thirza Leeuwenhage</strong>.</p>
          </div>
          <div class="tla-studio__phases tla-fade tla-d2">
            <div class="tla-phase-item">
              <span class="tla-phase-item__num">01</span>
              <div>
                <p class="tla-phase-item__label">Live nu</p>
                <p class="tla-phase-item__name">Moments</p>
              </div>
            </div>
            <div class="tla-phase-item">
              <span class="tla-phase-item__num">02</span>
              <div>
                <p class="tla-phase-item__label">In ontwikkeling</p>
                <p class="tla-phase-item__name">Experiences</p>
              </div>
            </div>
            <div class="tla-phase-item">
              <span class="tla-phase-item__num">03</span>
              <div>
                <p class="tla-phase-item__label">Toekomstvisie</p>
                <p class="tla-phase-item__name">Immersive Worlds</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── De drie pijlers ────────────────────────────── -->
    <section class="tla-pillars" id="pillars">
      <div class="tla-container">
        <div class="tla-section-header tla-fade">
          <span class="tla-overline">Waar we aan bouwen</span>
          <h2>Drie pijlers van ervaring</h2>
          <div class="tla-divider"></div>
        </div>
        <div class="tla-pillars__grid">
          <!-- Pijler 1 -->
          <div class="tla-pillar-card tla-fade tla-d1">
            <div class="tla-pillar-card__head">
              <span class="tla-pillar-card__num">01</span>
              <span class="tla-badge tla-badge--live">Nu beschikbaar</span>
            </div>
            <h3>Moments</h3>
            <p class="tla-pillar-card__tagline">Persoonlijk &middot; Betekenisvol &middot; Deelbaar</p>
            <p class="tla-pillar-card__desc">De momenten die er &eacute;cht toe doen &mdash; de soort die jarenlang nog worden naverteld. Onze eerste pijler richt zich op persoonlijke, emotionele en zorgvuldig vormgegeven producten.</p>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:auto;">
              <a href="https://weddingcambox.nl" class="tla-btn tla-btn--outline tla-btn--sm" target="_blank" rel="noopener">WeddingCamBox</a>
              <a href="https://shuttershare.nl" class="tla-btn tla-btn--outline tla-btn--sm" target="_blank" rel="noopener">ShutterShare</a>
              <span class="tla-btn tla-btn--outline tla-btn--sm" style="opacity:0.4;cursor:default;pointer-events:none;" aria-disabled="true">Murder Mystery &mdash; binnenkort</span>
            </div>
          </div>
          <!-- Pijler 2 -->
          <div class="tla-pillar-card tla-fade tla-d2">
            <div class="tla-pillar-card__head">
              <span class="tla-pillar-card__num">02</span>
              <span class="tla-badge tla-badge--dev">In ontwikkeling</span>
            </div>
            <h3>Experiences</h3>
            <p class="tla-pillar-card__tagline">Interactief &middot; Speels &middot; Verhalend</p>
            <p class="tla-pillar-card__desc">Puzzelroutes, interactieve installaties en verhalende spellen die ontworpen zijn voor &eacute;chte plekken. Gemaakt voor wie graag onderzoekt en ontdekt.</p>
            <a href="/puzzlequests/nl/" class="tla-btn tla-btn--outline tla-btn--sm" style="margin-top:auto;">Puzzle Quests</a>
          </div>
          <!-- Pijler 3 -->
          <div class="tla-pillar-card tla-fade tla-d3">
            <div class="tla-pillar-card__head">
              <span class="tla-pillar-card__num">03</span>
              <span class="tla-badge tla-badge--future">Toekomstvisie</span>
            </div>
            <h3>Immersive Worlds</h3>
            <p class="tla-pillar-card__tagline">Gelaagd &middot; Ruimtelijk &middot; Onvergetelijk</p>
            <p class="tla-pillar-card__desc">Grootschalige, plaatsgebonden verhalen voor steden, erfgoedlocaties en historische routes. Ervaringen die een plek veranderen in een levend verhaal.</p>
            <a href="/immersive/nl/" class="tla-btn tla-btn--outline tla-btn--sm" style="margin-top:auto;">Immersive Worlds</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Uitgelicht: WeddingCamBox ──────────────────── -->
    <section class="tla-featured">
      <div class="tla-container">
        <div class="tla-featured__grid">
          <div class="tla-featured__visual tla-fade">
            <span class="tla-featured__visual-mark">WCB</span>
            <span class="tla-badge tla-badge--live">Live nu</span>
          </div>
          <div class="tla-featured__content tla-fade tla-d2">
            <span class="tla-overline">Moments &mdash; Fase 1</span>
            <h2>WeddingCamBox</h2>
            <p>Onze eerste live propositie. WeddingCamBox geeft bruidsparen en hun gasten een persoonlijke manier om hun trouwdag vast te leggen &mdash; tien wegwerpcamera&rsquo;s in een kistje, beeldschoon eenvoudig.</p>
            <ul class="tla-featured__points">
              <li>Ontworpen rond het verhaal van het bruidspaar</li>
              <li>Simpel voor elke gast</li>
              <li>Levert iets op om te bewaren</li>
              <li>Nu beschikbaar</li>
            </ul>
            <div class="tla-featured__actions">
              <a href="https://weddingcambox.nl" class="tla-btn tla-btn--primary tla-btn--sm" target="_blank" rel="noopener">Bekijk WeddingCamBox</a>
              <a href="#contact" class="tla-btn tla-btn--outline tla-btn--sm">Neem contact op</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Roadmap ────────────────────────────────────── -->
    <section class="tla-roadmap" id="roadmap">
      <div class="tla-container">
        <div class="tla-section-header tla-fade">
          <span class="tla-overline">Waar we naartoe gaan</span>
          <h2>Onze roadmap</h2>
          <div class="tla-divider"></div>
        </div>
        <div class="tla-timeline tla-fade tla-d1">

          <!-- Nu – midden 2026 -->
          <div class="tla-timeline__item tla-timeline__item--active">
            <div class="tla-timeline__node"></div>
            <div class="tla-timeline__head">
              <h3>Nu &mdash; midden 2026</h3>
              <span class="tla-badge tla-badge--live">Actief</span>
            </div>
            <p class="tla-timeline__desc">WeddingCamBox hoogseizoen &middot; lancering ShutterShare &middot; greenscreen freelance werk &middot; ontwikkeling Murder Mystery sjabloon &middot; elektronicaprototypes Puzzle Quest</p>
          </div>

          <!-- Eind 2026 -->
          <div class="tla-timeline__item tla-timeline__item--outlined">
            <div class="tla-timeline__node"></div>
            <div class="tla-timeline__head">
              <h3>Eind 2026</h3>
              <span class="tla-badge tla-badge--dev">Op komst</span>
            </div>
            <p class="tla-timeline__desc">Jan-Truijen-prototype bij Museum Medelo &middot; eerste Puzzle Quest publieksproef &middot; ontwerp Meijelse kaarttafel</p>
          </div>

          <!-- 2027 -->
          <div class="tla-timeline__item tla-timeline__item--outlined">
            <div class="tla-timeline__node"></div>
            <div class="tla-timeline__head">
              <h3>2027</h3>
              <span class="tla-badge tla-badge--future">In planning</span>
            </div>
            <p class="tla-timeline__desc">Festival-debuut Puzzle Quest op Castlefest &amp; Elfia &middot; productieserie Magic Crystal &middot; sprekend portret aanbieden aan meer musea</p>
          </div>

          <!-- 2028+ -->
          <div class="tla-timeline__item tla-timeline__item--dashed">
            <div class="tla-timeline__node"></div>
            <div class="tla-timeline__head">
              <h3>2028 en verder</h3>
              <span class="tla-badge tla-badge--future">Toekomstvisie</span>
            </div>
            <p class="tla-timeline__desc">Opschaling Immersive Worlds &middot; verhalende ervaringen op stadsschaal &middot; plaatsgebonden verhalen op erfgoedlocaties en in de openbare ruimte</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Onze aanpak ────────────────────────────────── -->
    <section class="tla-values">
      <div class="tla-container">
        <div class="tla-section-header tla-fade">
          <span class="tla-overline">Onze aanpak</span>
          <h2>Waarom The Lions Alliance</h2>
          <div class="tla-divider"></div>
        </div>
        <div class="tla-values__grid">
          <div class="tla-value-card tla-fade tla-d1">
            <h3>Verhaal eerst</h3>
            <p>Elk project begint met een verhaalvraag. Welk verhaal helpen wij iemand vertellen?</p>
          </div>
          <div class="tla-value-card tla-fade tla-d2">
            <h3>Fysiek en digitaal</h3>
            <p>Wij combineren wat mensen kunnen vasthouden, scannen en delen &mdash; een brug tussen tastbaar en technologisch.</p>
          </div>
          <div class="tla-value-card tla-fade tla-d3">
            <h3>Met aandacht gebouwd</h3>
            <p>Wij maken liever minder, maar met meer zorg. Elk detail is overwogen, elke keuze bewust.</p>
          </div>
          <div class="tla-value-card tla-fade tla-d1">
            <h3>Gemaakt om te onthouden</h3>
            <p>Onze maatstaf voor succes is eenvoudig: heeft de ervaring iemand bijgebleven?</p>
          </div>
          <div class="tla-value-card tla-fade tla-d2">
            <h3>Van intiem tot grootschalig</h3>
            <p>Dezelfde manier van denken werkt voor een trouwproduct &eacute;n voor een verhalende ervaring op stadsschaal.</p>
          </div>
          <div class="tla-value-card tla-fade tla-d3">
            <h3>Partners voor de lange termijn</h3>
            <p>Wij bouwen duurzame relaties met locaties en organisaties op &mdash; geen losse opdrachten.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Contact ────────────────────────────────────── -->
    <section class="tla-contact" id="contact">
      <div class="tla-container">
        <span class="tla-overline tla-fade">Neem contact op</span>
        <h2 class="tla-fade tla-d1">Laten we samen iets bouwen<br />dat de moeite waard is om te onthouden</h2>
        <p class="tla-fade tla-d2">Of u nu een trouwdag voorbereidt, nieuwsgierig bent naar onze puzzelroutes, of een samenwerking wilt verkennen &mdash; we horen graag van u.</p>
        <div class="tla-contact__actions tla-fade tla-d3">
          <a href="/contact/nl/" class="tla-btn tla-btn--gold">Stuur ons een bericht</a>
          <a href="https://weddingcambox.nl" class="tla-btn tla-btn--ghost" target="_blank" rel="noopener">Bekijk WeddingCamBox</a>
        </div>
        <p class="tla-contact__email tla-fade tla-d3"><a href="mailto:hello@thelionsalliance.com">hello@thelionsalliance.com</a></p>
      </div>
    </section>

    <!-- ── Footer ─────────────────────────────────────── -->
    <footer class="tla-footer">
      <div class="tla-container">
        <div class="tla-footer__inner">
          <div class="tla-footer__brand">
            <span class="tla-footer__logo">The Lions <span>Alliance</span></span>
            <span class="tla-footer__tagline">Een creatieve ervaringsstudio</span>
          </div>
          <nav class="tla-footer__links">
            <a href="#studio">Studio</a>
            <a href="#pillars">Ons werk</a>
            <a href="#roadmap">Roadmap</a>
            <a href="/contact/nl/">Contact</a>
            <a href="https://weddingcambox.nl" target="_blank" rel="noopener">WeddingCamBox</a>
            <a href="https://shuttershare.nl" target="_blank" rel="noopener">ShutterShare</a>
            <a href="/immersive/nl/">Immersive Worlds</a>
            <a href="/puzzlequests/nl/">Puzzle Quests</a>
            <a href="/" hreflang="en" lang="en">English version</a>
          </nav>
        </div>
        <p class="tla-footer__copy">&copy; {year} The Lions Alliance. Alle rechten voorbehouden.</p>
      </div>
    </footer>

    <!-- ── Scripts ─────────────────────────────────────── -->
    <script>
      const nav = document.getElementById('tla-nav');
      window.addEventListener('scroll', () => {
        nav.classList.toggle('scrolled', window.scrollY > 40);
      }, { passive: true });

      const hamburger = document.getElementById('tla-hamburger');
      const mobileMenu = document.getElementById('tla-mobile-menu');
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        mobileMenu.classList.toggle('open');
      });

      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('active');
          mobileMenu.classList.remove('open');
        });
      });

      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          const target = document.querySelector(anchor.getAttribute('href'));
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });

      const faders = document.querySelectorAll('.tla-fade');
      const fadeObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('tla-visible');
            fadeObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      faders.forEach(el => fadeObserver.observe(el));
    </script>
  </body>
</html>
