---
import "../../../styles/homepage.css";
import "../../../styles/contact.css";
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact &mdash; The Lions Alliance</title>
    <meta name="description" content="Neem contact op met The Lions Alliance — voor samenwerkingen met musea, Puzzle Quest-vragen, WeddingCamBox-boekingen, studio-partnerschappen of algemene vragen." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="en" href="https://thelionsalliance.com/contact/" />
    <link rel="alternate" hreflang="nl" href="https://thelionsalliance.com/contact/nl/" />
    <link rel="alternate" hreflang="x-default" href="https://thelionsalliance.com/contact/" />
  </head>
  <body class="tla-page">

    <!-- ── Navigatie ──────────────────────────────────── -->
    <nav class="tla-nav" id="tla-nav">
      <div class="tla-nav__inner tla-container">
        <a href="/nl/" class="tla-nav__logo">The Lions <span>Alliance</span></a>
        <ul class="tla-nav__links">
          <li><a href="/nl/#studio">Studio</a></li>
          <li><a href="/nl/#pillars">Ons werk</a></li>
          <li><a href="/puzzlequests/nl/">Puzzle Quests</a></li>
          <li><a href="/immersive/nl/">Immersive Worlds</a></li>
        </ul>
        <div class="tla-nav__actions">
          <a href="/contact/" class="tla-nav__lang" hreflang="en" lang="en" title="View in English">EN</a>
          <a href="/nl/" class="tla-nav__cta">&larr; Studio</a>
        </div>
        <button class="tla-nav__hamburger" id="tla-hamburger" aria-label="Menu openen">
          <span></span><span></span><span></span>
        </button>
      </div>
      <div class="tla-nav__mobile" id="tla-mobile-menu">
        <a href="/nl/#studio">Studio</a>
        <a href="/nl/#pillars">Ons werk</a>
        <a href="/puzzlequests/nl/">Puzzle Quests</a>
        <a href="/immersive/nl/">Immersive Worlds</a>
        <a href="/contact/" hreflang="en" lang="en">View in English</a>
        <a href="/nl/">&larr; Terug naar de studio</a>
      </div>
    </nav>

    <!-- ── Contactpagina ──────────────────────────────── -->
    <section class="tla-contactpage">
      <div class="tla-container tla-contactpage__inner">
        <header class="tla-contactpage__intro tla-fade">
          <span class="tla-overline">Neem contact op</span>
          <h1>Laten we een gesprek beginnen</h1>
          <p>
            Of u nu een museum vertegenwoordigt en een Puzzle Quest wilt verkennen, een trouwdag plant, een locatie heeft die zich leent voor een immersieve samenwerking, of gewoon nieuwsgierig bent naar de studio &mdash; wij horen graag van u. Vul het formulier hieronder in, en wij reageren binnen een tot twee werkdagen.
          </p>
          <p class="tla-contactpage__direct">
            U kunt ons ook rechtstreeks bereiken op <a href="mailto:hello@thelionsalliance.com">hello@thelionsalliance.com</a>.
          </p>
        </header>

        <div class="tla-contactpage__card tla-fade tla-d1">
          <form class="tla-form" id="contactForm" novalidate>
            <div class="tla-form__row">
              <div class="tla-form__group">
                <label for="cName">Uw naam</label>
                <input type="text" id="cName" name="name" autocomplete="name" placeholder="bijv. Anna van der Meer" required />
                <span class="tla-form__error" id="nameError"></span>
              </div>
              <div class="tla-form__group">
                <label for="cEmail">E-mailadres</label>
                <input type="email" id="cEmail" name="email" autocomplete="email" placeholder="anna@voorbeeld.nl" required />
                <span class="tla-form__error" id="emailError"></span>
              </div>
            </div>

            <div class="tla-form__group">
              <label for="cTopic">Waar gaat uw vraag over?</label>
              <select id="cTopic" name="topic">
                <option value="Puzzle Quests — museum / heritage venue">Puzzle Quests &mdash; museum of erfgoedlocatie</option>
                <option value="WeddingCamBox / ShutterShare booking">WeddingCamBox- of ShutterShare-boeking</option>
                <option value="Studio collaboration / partnership">Studio-samenwerking of partnerschap</option>
                <option value="Immersive Worlds">Immersive Worlds</option>
                <option value="Press / media">Pers of media</option>
                <option value="General question">Algemene vraag</option>
                <option value="Other">Iets anders</option>
              </select>
            </div>

            <div class="tla-form__group">
              <label for="cMessage">Uw bericht</label>
              <textarea id="cMessage" name="message" rows="6" placeholder="Vertel ons wat u in gedachten heeft&hellip;" required></textarea>
              <span class="tla-form__error" id="msgError"></span>
            </div>

            <button type="submit" class="tla-btn tla-btn--gold tla-btn--full" id="submitBtn">Verstuur bericht</button>
          </form>

          <div class="tla-form__success" id="formSuccess">
            <div class="tla-form__success-icon">&#10070;</div>
            <h2>Bericht verstuurd</h2>
            <p>Dank voor uw bericht. Wij reageren binnen een tot twee werkdagen. Een bevestiging is verzonden naar uw e-mailadres.</p>
            <a href="/nl/" class="tla-form__success-link">&larr; Terug naar de studio</a>
          </div>
        </div>

        <aside class="tla-contactpage__aside tla-fade tla-d2">
          <h3>Andere manieren om ons te bereiken</h3>
          <ul class="tla-contactpage__channels">
            <li>
              <span class="tla-contactpage__channel-label">Studio-e-mail</span>
              <a href="mailto:hello@thelionsalliance.com">hello@thelionsalliance.com</a>
            </li>
            <li>
              <span class="tla-contactpage__channel-label">WeddingCamBox boekingen</span>
              <a href="https://weddingcambox.nl" target="_blank" rel="noopener">weddingcambox.nl</a>
            </li>
            <li>
              <span class="tla-contactpage__channel-label">ShutterShare evenementen</span>
              <a href="https://shuttershare.nl" target="_blank" rel="noopener">shuttershare.nl</a>
            </li>
            <li>
              <span class="tla-contactpage__channel-label">Puzzle Quests &middot; pilotlocatie</span>
              <span class="tla-contactpage__channel-text">Museum Medelo, Tomveld 2, Meijel</span>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- ── Footer ─────────────────────────────────────── -->
    <footer class="tla-footer">
      <div class="tla-container">
        <div class="tla-footer__inner">
          <div class="tla-footer__brand">
            <span class="tla-footer__logo">The Lions <span>Alliance</span></span>
            <span class="tla-footer__tagline">Een creatieve ervaringsstudio</span>
          </div>
          <nav class="tla-footer__links">
            <a href="/nl/#studio">Studio</a>
            <a href="/nl/#pillars">Ons werk</a>
            <a href="/puzzlequests/nl/">Puzzle Quests</a>
            <a href="/immersive/nl/">Immersive Worlds</a>
            <a href="/contact/nl/">Contact</a>
            <a href="/contact/" hreflang="en" lang="en">English version</a>
          </nav>
        </div>
        <p class="tla-footer__copy">&copy; {year} The Lions Alliance. Alle rechten voorbehouden.</p>
      </div>
    </footer>

    <script>
      const API_URL = 'https://api.weddingcambox.nl';

      const nav = document.getElementById('tla-nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          nav.classList.toggle('scrolled', window.scrollY > 40);
        }, { passive: true });
      }

      // Fade-in observer — zonder dit blijven alle .tla-fade elementen
      // op opacity:0 (uit homepage.css) en lijkt de pagina leeg
      const faders = document.querySelectorAll('.tla-fade');
      if (faders.length && 'IntersectionObserver' in window) {
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('tla-visible');
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.05 }
        );
        faders.forEach((el) => obs.observe(el));
      } else {
        faders.forEach((el) => el.classList.add('tla-visible'));
      }

      const hamburger = document.getElementById('tla-hamburger');
      const mobileMenu = document.getElementById('tla-mobile-menu');
      if (hamburger && mobileMenu) {
        hamburger.addEventListener('click', () => {
          const open = mobileMenu.classList.toggle('open');
          hamburger.classList.toggle('open', open);
          hamburger.setAttribute('aria-expanded', String(open));
        });
        mobileMenu.querySelectorAll('a').forEach((a) => {
          a.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
            hamburger.classList.remove('open');
            hamburger.setAttribute('aria-expanded', 'false');
          });
        });
      }

      const form = document.getElementById('contactForm');
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          const nameEl  = document.getElementById('cName');
          const emailEl = document.getElementById('cEmail');
          const topicEl = document.getElementById('cTopic');
          const msgEl   = document.getElementById('cMessage');
          const btn     = document.getElementById('submitBtn');

          const name    = nameEl.value.trim();
          const email   = emailEl.value.trim();
          const topic   = topicEl.value;
          const message = msgEl.value.trim();

          document.getElementById('nameError').textContent  = '';
          document.getElementById('emailError').textContent = '';
          document.getElementById('msgError').textContent   = '';

          let valid = true;
          if (!name) {
            document.getElementById('nameError').textContent = 'Vul uw naam in.';
            valid = false;
          }
          if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            document.getElementById('emailError').textContent = 'Vul een geldig e-mailadres in.';
            valid = false;
          }
          if (!message) {
            document.getElementById('msgError').textContent = 'Schrijf een bericht.';
            valid = false;
          }
          if (!valid) return;

          btn.disabled    = true;
          btn.textContent = 'Versturen…';

          try {
            const res = await fetch(`${API_URL}/api/tla/contact`, {
              method:  'POST',
              headers: { 'Content-Type': 'application/json' },
              body:    JSON.stringify({ name, email, topic, message }),
            });
            if (!res.ok) throw new Error('Server error');
            form.classList.add('hidden');
            document.getElementById('formSuccess').classList.add('visible');
            window.scrollTo({ top: 0, behavior: 'smooth' });
          } catch (err) {
            btn.disabled    = false;
            btn.textContent = 'Verstuur bericht';
            document.getElementById('msgError').textContent =
              'Er ging iets mis. Probeer het opnieuw of mail ons rechtstreeks op hello@thelionsalliance.com.';
          }
        });
      }
    </script>
  </body>
</html>
