---
import "../../styles/homepage.css";
import "../../styles/puzzlequests.css";
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Puzzle Quests &mdash; The Lions Alliance</title>
    <meta name="description" content="Puzzle Quests is a family of interactive physical prop experiences by The Lions Alliance — built around story, exploration, and hands-on discovery." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="tla-page">

    <!-- ── Navigation ─────────────────────────────────── -->
    <nav class="tla-nav" id="tla-nav">
      <div class="tla-nav__inner tla-container">
        <a href="/" class="tla-nav__logo">The Lions <span>Alliance</span></a>
        <ul class="tla-nav__links">
          <li><a href="#overview">Overview</a></li>
          <li><a href="#how-it-works">How It Works</a></li>
          <li><a href="#props">The Props</a></li>
          <li><a href="#collaborate">Collaborate</a></li>
        </ul>
        <a href="/" class="tla-nav__cta">&larr; Back to Studio</a>
        <button class="tla-nav__hamburger" id="hamburger" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </div>
      <div class="tla-nav__mobile" id="mobile-menu">
        <a href="#overview">Overview</a>
        <a href="#how-it-works">How It Works</a>
        <a href="#props">The Props</a>
        <a href="#collaborate">Collaborate</a>
        <a href="/">&larr; Back to Studio</a>
      </div>
    </nav>

    <!-- ── Hero ───────────────────────────────────────── -->
    <section class="pl-hero" id="home">
      <div class="tla-container pl-hero__inner">
        <div class="pl-hero__text tla-fade">
          <div class="pl-hero__breadcrumb">
            <a href="/">The Lions Alliance</a>
            <span class="pl-hero__breadcrumb-sep">/</span>
            <span>Experiences Pillar</span>
          </div>
          <div class="pl-hero__badges">
            <span class="tla-badge tla-badge--dev">In Development</span>
            <span class="tla-badge tla-badge--future">Festivals 2027</span>
          </div>
          <h1 class="pl-hero__title">Puzzle <em>Quests</em></h1>
          <p class="pl-hero__subtitle">
            A family of interactive physical prop experiences built around story, exploration, and hands-on discovery. Each prop is a self-contained adventure &mdash; perfect for events, parties, and birthdays. Part of The Lions Alliance&rsquo;s Experiences pillar.
          </p>
          <div class="pl-hero__ctas">
            <a href="#collaborate" class="tla-btn tla-btn--sage">Follow the project</a>
            <a href="/" class="tla-btn tla-btn--outline">&larr; The Lions Alliance</a>
          </div>
        </div>
        <div class="pl-hero__visual tla-fade tla-d1">
          <div class="pl-hero__placeholder">
            <span class="pl-hero__placeholder-icon">&#9670;</span>
          </div>
          <span class="pl-hero__placeholder-caption">Concept visual &mdash; in development</span>
        </div>
      </div>
    </section>

    <!-- ── The Concept ────────────────────────────────── -->
    <section class="pl-overview" id="overview">
      <div class="tla-container pl-overview__inner">
        <div class="pl-overview__text tla-fade">
          <span class="tla-overline">The concept</span>
          <h2 class="tla-section-header">Story-driven exploration through physical interaction</h2>
          <p>
            Puzzle Quests is a family of interactive physical props, each one a self-contained experience. Participants explore, decode, and discover &mdash; guided not by a screen or a host, but by the objects in their hands and the story woven into the world around them.
          </p>
          <p>
            Each prop is designed for a different level of complexity and audience. From a quick seek-and-find adventure to a deep cipher-and-story challenge, Puzzle Quests scales to the occasion. They work as a special addition to events, birthday parties, and any gathering where you want to give people something genuinely memorable to do.
          </p>
          <p>
            The first real-audience tests are planned for <strong>Castlefest and Elfia 2027</strong>. We&rsquo;re currently in electronics prototyping and route design.
          </p>
          <div class="pl-tags">
            <span class="pl-tag">Physical props</span>
            <span class="pl-tag">Story-driven</span>
            <span class="pl-tag">Events &amp; parties</span>
            <span class="pl-tag">Birthdays</span>
            <span class="pl-tag">Festivals</span>
            <span class="pl-tag">Group play</span>
          </div>
        </div>
        <div class="pl-overview__visual tla-fade tla-d1">
          <div class="pl-overview__img">&#9670;</div>
        </div>
      </div>
    </section>

    <div class="tla-divider"></div>

    <!-- ── How It Works ───────────────────────────────── -->
    <section class="pl-steps-section" id="how-it-works">
      <div class="tla-container">
        <div class="tla-fade" style="text-align:center;">
          <span class="tla-overline">How it works</span>
          <h2 class="tla-section-header">Each prop is its own complete adventure &mdash; pick it up and play.</h2>
        </div>
        <div class="pl-steps">
          <div class="pl-step tla-fade">
            <div class="pl-step__number">I</div>
            <div class="pl-step__title">Receive the prop</div>
            <div class="pl-step__desc">Each Puzzle Quest prop arrives ready to play &mdash; no app, no screen, no setup required.</div>
          </div>
          <div class="pl-step tla-fade tla-d1">
            <div class="pl-step__number">II</div>
            <div class="pl-step__title">Follow the story</div>
            <div class="pl-step__desc">Clues, ciphers, and hidden interactions unfold the narrative. Every prop has its own flavour of discovery.</div>
          </div>
          <div class="pl-step tla-fade tla-d2">
            <div class="pl-step__number">III</div>
            <div class="pl-step__title">Reach the reveal</div>
            <div class="pl-step__desc">Every quest builds to a satisfying conclusion &mdash; a moment worth sharing and remembering.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── The Props ──────────────────────────────────── -->
    <section class="pl-applications" id="props">
      <div class="tla-container">
        <div class="tla-fade" style="text-align:center;">
          <span class="tla-overline">The props</span>
          <h2 class="tla-section-header">Three props. Three kinds of adventure.</h2>
        </div>
        <div class="pl-concept-grid">
          <div class="pl-concept-card tla-fade">
            <span class="pl-concept-card__icon">&#128273;</span>
            <div class="pl-concept-card__title">Skeleton Key</div>
            <div class="pl-concept-card__desc">A seek-and-find adventure driven by NFC. Tap locations, unlock story fragments, and piece together the mystery. Perfect for outdoor routes and venue exploration.</div>
          </div>
          <div class="pl-concept-card tla-fade tla-d1">
            <span class="pl-concept-card__icon">&#128214;</span>
            <div class="pl-concept-card__title">Living Chronicle</div>
            <div class="pl-concept-card__desc">A cipher and story-decode experience built around an E-ink display. The prop reveals the narrative piece by piece as players solve encoded clues woven into the story.</div>
          </div>
          <div class="pl-concept-card tla-fade tla-d2">
            <span class="pl-concept-card__icon">&#127982;</span>
            <div class="pl-concept-card__title">Puzzle Lantern</div>
            <div class="pl-concept-card__desc">The full sensory experience &mdash; light, UV, and sensor-based interactions guide players through a layered route. Atmospheric, immersive, and built to surprise at every turn.</div>
          </div>
        </div>

        <!-- Magic Crystal upsell -->
        <div class="tla-fade" style="margin-top:2.5rem; padding:1.5rem 2rem; background:var(--tla-surface,#f8f6f0); border-radius:12px; border-left:4px solid var(--tla-gold,#c9aa71); max-width:680px; margin-left:auto; margin-right:auto;">
          <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.5rem;">
            <span style="font-size:1.5rem;">&#10024;</span>
            <strong style="font-size:1.05rem;">Magic Crystal &mdash; Souvenir Collectible</strong>
            <span class="tla-badge tla-badge--future" style="margin-left:auto;">Coming Soon</span>
          </div>
          <p style="margin:0; color:var(--tla-muted,#666); font-size:0.95rem;">A physical keepsake that guests take home from any Puzzle Quest experience. Part souvenir, part collectible &mdash; the Magic Crystal is an optional upsell that turns a great event into something participants carry with them long after.</p>
        </div>
      </div>
    </section>

    <!-- ── Development Status ─────────────────────────── -->
    <section class="pl-development" id="status">
      <div class="tla-container">
        <div class="tla-fade" style="text-align:center;">
          <span class="tla-overline">Progress</span>
          <h2 class="tla-section-header">Where we are right now</h2>
        </div>
        <div class="pl-phase-grid">
          <div class="pl-phase-card pl-phase-card--done tla-fade">
            <div class="pl-phase-card__number">01</div>
            <div class="pl-phase-card__title">Concept &amp; Prop Design</div>
            <span class="pl-phase-card__badge">Complete</span>
          </div>
          <div class="pl-phase-card pl-phase-card--active tla-fade tla-d1">
            <div class="pl-phase-card__number">02</div>
            <div class="pl-phase-card__title">Electronics Prototyping</div>
            <span class="pl-phase-card__badge">In Progress</span>
          </div>
          <div class="pl-phase-card pl-phase-card--upcoming tla-fade tla-d2">
            <div class="pl-phase-card__number">03</div>
            <div class="pl-phase-card__title">Real-Audience Testing</div>
            <span class="pl-phase-card__badge">Late 2026</span>
          </div>
          <div class="pl-phase-card pl-phase-card--future tla-fade tla-d3">
            <div class="pl-phase-card__number">04</div>
            <div class="pl-phase-card__title">Festival Debut &mdash; Castlefest &amp; Elfia</div>
            <span class="pl-phase-card__badge">2027</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Our Thinking ───────────────────────────────── -->
    <section class="pl-philosophy">
      <div class="tla-container">
        <div class="tla-fade" style="text-align:center;">
          <span class="tla-overline">Our thinking</span>
          <h2 class="tla-section-header">Why we are building this</h2>
        </div>
        <div class="pl-philosophy__grid">
          <div class="pl-philosophy__card tla-fade">
            <span class="pl-philosophy__card-icon">&#9995;</span>
            <div class="pl-philosophy__card-title">Tactile over purely digital</div>
            <div class="pl-philosophy__card-desc">Real physical interaction creates moments that screens cannot replicate &mdash; touch, weight, space, and surprise become part of the story.</div>
          </div>
          <div class="pl-philosophy__card tla-fade tla-d1">
            <span class="pl-philosophy__card-icon">&#129309;</span>
            <div class="pl-philosophy__card-title">Shared adventure by design</div>
            <div class="pl-philosophy__card-desc">Built for groups, families, and friends &mdash; the experience is designed to be discovered together, not alone.</div>
          </div>
          <div class="pl-philosophy__card tla-fade tla-d2">
            <span class="pl-philosophy__card-icon">&#127761;</span>
            <div class="pl-philosophy__card-title">Atmosphere as a design material</div>
            <div class="pl-philosophy__card-desc">Light, space, timing, and mood are deliberate tools &mdash; every element contributes to the feeling of the journey.</div>
          </div>
          <div class="pl-philosophy__card tla-fade tla-d3">
            <span class="pl-philosophy__card-icon">&#127759;</span>
            <div class="pl-philosophy__card-title">Storytelling through place</div>
            <div class="pl-philosophy__card-desc">The environment is a co-author. Location, landscape, and architecture shape the narrative as much as any script.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Collaboration CTA ──────────────────────────── -->
    <section class="pl-collaborate" id="collaborate">
      <div class="tla-container pl-collaborate__inner">
        <div class="pl-collaborate__text tla-fade">
          <span class="tla-overline">Early interest</span>
          <h2 class="tla-section-header">Bring a Puzzle Quest to your event or venue</h2>
          <p>
            Puzzle Quests is in active development and we&rsquo;re open to early conversations. Whether you organise events, run a venue, or want to offer guests something truly different at a birthday, festival, or team gathering &mdash; we&rsquo;d love to hear from you.
          </p>
          <p>
            We&rsquo;re looking for pilot partners, creative collaborators, and spaces where physical storytelling can come to life.
          </p>
          <div class="pl-collaborate__ctas">
            <a href="mailto:hello@thelionsalliance.com" class="tla-btn tla-btn--gold">Get in touch</a>
            <a href="/" class="tla-btn tla-btn--outline">Explore the studio &rarr;</a>
          </div>
        </div>
        <div class="pl-collaborate__audiences tla-fade tla-d1">
          <ul class="pl-audience-list">
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Museums &amp; heritage venues</li>
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Campsites &amp; outdoor locations</li>
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Event &amp; experience organisers</li>
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Tourism organisations</li>
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Birthday parties &amp; private events</li>
            <li class="pl-audience-item"><span class="pl-audience-dot"></span>Festivals (Castlefest &amp; Elfia 2027)</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ── FAQ ────────────────────────────────────────── -->
    <section class="pl-faq">
      <div class="tla-container">
        <div class="tla-fade" style="text-align:center;">
          <span class="tla-overline">FAQ</span>
          <h2 class="tla-section-header">Common questions</h2>
        </div>
        <div class="pl-faq__list">
          <div class="pl-faq__item tla-fade">
            <div class="pl-faq__question">Is Puzzle Quests available yet?</div>
            <div class="pl-faq__answer">Not yet for the public. We&rsquo;re in active prototype development and planning our first real-audience tests for late 2026. Our festival debut at Castlefest and Elfia is planned for 2027. Get in touch if you&rsquo;d like to be part of the journey.</div>
          </div>
          <div class="pl-faq__item tla-fade tla-d1">
            <div class="pl-faq__question">What are the different props?</div>
            <div class="pl-faq__answer">There are three props at different complexity levels: the <strong>Skeleton Key</strong> (seek-and-find, NFC-based), the <strong>Living Chronicle</strong> (cipher and story-decode, E-ink display), and the <strong>Puzzle Lantern</strong> (full light, UV, and sensor-driven route experience). Each is self-contained and playable without any additional app or screen.</div>
          </div>
          <div class="pl-faq__item tla-fade tla-d2">
            <div class="pl-faq__question">What kind of events are they suited for?</div>
            <div class="pl-faq__answer">Puzzle Quests are designed as a special addition to events, birthday parties, team days, and gatherings where you want guests to actually do something memorable together &mdash; not just attend. They also work as installations at museums, campsites, heritage venues, and festivals.</div>
          </div>
          <div class="pl-faq__item tla-fade tla-d3">
            <div class="pl-faq__question">What is the Magic Crystal?</div>
            <div class="pl-faq__answer">The Magic Crystal is an optional souvenir collectible &mdash; a physical keepsake guests take home after completing a Puzzle Quest experience. It&rsquo;s an upsell item designed to make the memory tangible and lasting. Production is planned alongside the 2027 festival debut.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Footer ─────────────────────────────────────── -->
    <footer class="tla-footer">
      <div class="tla-container tla-footer__inner">
        <div class="tla-footer__brand">
          <div class="tla-footer__logo">The Lions Alliance</div>
          <p class="tla-footer__tagline">Creative studio for meaningful projects.</p>
        </div>
        <div class="tla-footer__links">
          <a href="/">Studio</a>
          <a href="#overview">Overview</a>
          <a href="#props">The Props</a>
          <a href="#collaborate">Collaborate</a>
        </div>
      </div>
      <div class="tla-container tla-footer__bottom">
        <span>&copy; {year} The Lions Alliance. All rights reserved.</span>
      </div>
    </footer>

    <!-- ── Scripts ─────────────────────────────────────── -->
    <script>
      const nav = document.getElementById('tla-nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          nav.classList.toggle('scrolled', window.scrollY > 40);
        });
      }

      const faders = document.querySelectorAll('.tla-fade');
      if (faders.length && 'IntersectionObserver' in window) {
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('tla-visible');
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.15 }
        );
        faders.forEach((el) => obs.observe(el));
      } else {
        faders.forEach((el) => el.classList.add('tla-visible'));
      }

      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');
      if (hamburger && mobileMenu) {
        hamburger.addEventListener('click', () => {
          const open = mobileMenu.classList.toggle('open');
          hamburger.classList.toggle('open', open);
          hamburger.setAttribute('aria-expanded', String(open));
        });
        mobileMenu.querySelectorAll('a').forEach((a) => {
          a.addEventListener('click', () => {
            mobileMenu.classList.remove('open');
            hamburger.classList.remove('open');
            hamburger.setAttribute('aria-expanded', 'false');
          });
        });
      }
    </script>
  </body>
</html>
