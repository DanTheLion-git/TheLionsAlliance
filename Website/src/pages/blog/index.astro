---
import Layout from "../../layouts/ResumeLayout.astro";
import { getPosts, type WPPostEnriched } from "../../lib/wp";
import { decodeHTML } from "../../lib/html";

const posts: WPPostEnriched[] = await getPosts(100);
---

<Layout title="Blog | The Lions Alliance">
  <section class="section">
    <div class="section-header">
      <a href="/resume/" class="section-link">← Back to home</a>
      <h1 class="section-title">Blog</h1>
      <p class="section-subtitle">
        Project logs, experiments, behind-the-scenes notes, and progress updates.
      </p>
    </div>

    {posts.length === 0 && (
      <div class="contact-block">
        <p>No posts found yet.</p>
        <p>Once you publish on WordPress, they'll show up here automatically.</p>
      </div>
    )}

    {posts.length > 0 && (
      <div>
        <p class="post-meta" style="margin-bottom: 1.5rem;">
          {posts.length} post{posts.length === 1 ? "" : "s"}
        </p>

        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-card">
              <a href={`/blog/${post.slug}/`} class="post-card-link">
                {post.featuredImage && (
                  <div class="post-card-image">
                    <img src={post.featuredImage} alt="" loading="lazy" />
                  </div>
                )}
                <div class="post-card-body">
                  <div class="post-title-row">
                    <span class="post-title">
                      {decodeHTML(post.title.rendered)}
                    </span>
                    <span class={`lang-badge lang-${post.lang}`}>{post.lang === "nl" ? "🇳🇱" : "🇬🇧"}</span>
                  </div>

                  <p class="post-meta">
                    <time datetime={post.date}>
                      {new Date(post.date).toLocaleDateString("en-GB", {
                        year: "numeric",
                        month: "short",
                        day: "2-digit",
                      })}
                    </time>
                  </p>

                  <p class="post-excerpt" set:html={post.excerpt.rendered} />

                  <p style="margin-top: 0.75rem;">
                    <span class="section-link">Read post →</span>
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
</Layout>