---
/**
 * Standalone "Songs with Friends" print page — zero site CSS, zero navigation.
 *
 * All 60 card slots are pre-built as static HTML at Astro build time.
 * JavaScript only fills in QR images and text; the grid is always present
 * even if print fires before JS completes.
 *
 * Supports playlists up to 600 tracks via sets of 60.
 * Data arrives via localStorage key `swf_print_sets` (array of track arrays).
 * The set index is read from the URL query param `?set=0`.
 *
 * Layout: 5 sheets × 12 cards (3 cols × 4 rows) = 60 cards max per set.
 * Double-sided: LONG-EDGE flip (flip left/right like a book).
 *   Back column order = front columns mirrored per row so they align after the flip.
 */
const SHEETS    = 5;
const COLS      = 3;
const ROWS      = 4;
const PER_PAGE  = COLS * ROWS; // 12

function mirrorColumns(front: number[]): number[] {
  const out: number[] = [];
  for (let r = 0; r < ROWS; r++) {
    const row = front.slice(r * COLS, (r + 1) * COLS);
    out.push(...[...row].reverse());
  }
  return out;
}

const sheets = Array.from({ length: SHEETS }, (_, s) => {
  const front = Array.from({ length: PER_PAGE }, (_, i) => s * PER_PAGE + i + 1);
  return { front, back: mirrorColumns(front), num: s + 1 };
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Songs with Friends — Print Sheet</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; color: #000; }

    /* ── Controls (screen only) ────────────────────────────────────────── */
    #controls {
      position: sticky; top: 0; z-index: 99;
      background: #111; color: #fff;
      display: flex; align-items: center; gap: 0.8rem;
      padding: 0.55rem 1rem; font-size: 0.83rem;
    }
    #controls button {
      background: #fff; color: #111; border: none; border-radius: 4px;
      padding: 0.32rem 0.85rem; font-size: 0.8rem; font-weight: 700; cursor: pointer;
    }
    #controls button:disabled { opacity: 0.4; cursor: default; }
    #controls button:not(:disabled):hover { background: #ddd; }
    #info { opacity: 0.65; font-size: 0.76rem; }

    #status {
      background: #f5f5f5; border-bottom: 1px solid #ddd;
      padding: 0.6rem 1rem; font-size: 0.82rem; color: #444;
    }

    /* ── A4 page wrapper ───────────────────────────────────────────────── */
    .page-wrapper {
      /* Both screen and print: true A4 dimensions, 10 mm padding */
      width: 210mm;
      height: 297mm;
      padding: 10mm;
      overflow: hidden;
      background: #fff;
    }

    #set-nav button:disabled { opacity: 0.4; cursor: default; }
    #set-nav button:not(:disabled):hover { background: #ddd; }

    .page-label {
      font-size: 0.68rem; color: #999; margin-bottom: 2mm;
      font-family: Arial, sans-serif;
    }

    /* ── Card grid ─────────────────────────────────────────────────────────
     * Printable area (10 mm @page margins): 190 mm × 277 mm
     *   card width  = (190 − 2 gaps × 3 mm) / 3 cols = 61.33 mm
     *   card height = (277 − 3 gaps × 3 mm) / 4 rows = 67.00 mm
     * Inline style on each .cards-grid duplicates these so they apply even
     * if the stylesheet is not parsed before print fires.
     */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 61.33mm);
      grid-template-rows: repeat(4, 67mm);
      gap: 3mm;
    }

    /* ── Individual card ───────────────────────────────────────────────── */
    .print-card {
      width:  61.33mm;
      height: 67mm;
      border: 0.35mm solid #c8c8c8;
      border-radius: 1.5mm;
      overflow: hidden;
      background: #fff;
    }
    /* dim unfilled placeholders in print so only real cards show */
    .print-card.empty { border-color: #ebebeb; }
    @media print { .print-card.empty * { visibility: hidden; } }

    /* ── Front (QR) card ───────────────────────────────────────────────── */
    .qr-card {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 3mm; gap: 1.5mm;
    }
    .card-brand {
      font-size: 6pt; font-weight: 900; letter-spacing: 2px;
      color: #aaa; text-transform: uppercase;
    }
    .print-card.loaded .card-brand { color: #555; }

    /* QR placeholder square */
    .qr-ph {
      width: 76%; aspect-ratio: 1 / 1;
      background: #f0f0f0; border: 0.3mm solid #ddd; border-radius: 1mm;
    }
    .qr-img { width: 82%; height: auto; display: none; }
    .print-card.loaded .qr-ph  { display: none; }
    .print-card.loaded .qr-img { display: block; }

    /* ── Back (info) card ──────────────────────────────────────────────── */
    .info-card {
      display: flex; flex-direction: column;
      align-items: center; justify-content: space-between;
      padding: 5mm 3mm; text-align: center;
    }
    .info-artist { font-size: 10pt; font-weight: 400; line-height: 1.3; width: 100%; color: #ccc; overflow-wrap: break-word; word-break: break-word; }
    .info-year   { font-size: 58pt; font-weight: 900; line-height: 1; color: #e8e8e8; }
    .info-song   { font-size: 10pt; font-weight: 700; line-height: 1.3; width: 100%; color: #ccc; overflow-wrap: break-word; word-break: break-word; }
    .print-card.loaded .info-artist,
    .print-card.loaded .info-song   { color: #000; overflow-wrap: break-word; word-break: break-word; }
    .print-card.loaded .info-year   { color: #000; }

    /* ── Screen preview ────────────────────────────────────────────────── */
    @media screen {
      body { background: #555; }
      .page-wrapper {
        margin: 6mm auto;
        box-shadow: 0 2px 16px rgba(0,0,0,.45);
      }
    }

    /* ── Print output ──────────────────────────────────────────────────── */
    @media print {
      #controls, #status, #set-nav { display: none !important; }

      .page-label { display: none; }

      .page-wrapper {
        margin: 0; padding: 10mm;
        page-break-after: always;
        break-after: page;
        box-shadow: none;
      }
      .page-wrapper:last-child {
        page-break-after: avoid;
        break-after: auto;
      }

      @page { size: A4 portrait; margin: 0; }
    }
  </style>
</head>
<body>

<!-- ── Controls bar ──────────────────────────────────────────────────────── -->
<div id="controls">
  <button id="btn-print" onclick="window.print()" disabled>🖨 Print / Save PDF</button>
  <button onclick="window.close()">✕ Close</button>
  <span id="info">Waiting for track data…</span>
</div>
<div id="set-nav" style="display:none;background:#222;color:#fff;padding:0.45rem 1rem;font-size:0.82rem;align-items:center;gap:0.6rem;">
  <span id="set-label"></span>
  <button id="btn-prev-set" style="background:#fff;color:#111;border:none;border-radius:4px;padding:0.25rem 0.6rem;font-size:0.78rem;font-weight:700;cursor:pointer;">← Prev Set</button>
  <button id="btn-next-set" style="background:#fff;color:#111;border:none;border-radius:4px;padding:0.25rem 0.6rem;font-size:0.78rem;font-weight:700;cursor:pointer;">Next Set →</button>
</div>
<div id="status">⏳ Reading track data…</div>

<!-- ── Static pages — all 60 slots pre-built at build time ───────────────── -->
<div id="pages">
  {sheets.map(sheet => (<>

    {/* Front page */}
    <div class="page-wrapper" data-sheet={sheet.num} data-side="front">
      <div class="cards-grid"
           style="display:grid;grid-template-columns:repeat(3,61.33mm);grid-template-rows:repeat(4,67mm);gap:3mm;">
        {sheet.front.map(n => (
          <div class="print-card qr-card empty" data-card={n}>
            <div class="card-brand">SONGS WITH FRIENDS</div>
            <div class="qr-ph"></div>
            <img class="qr-img" alt="QR" />
          </div>
        ))}
      </div>
    </div>

    {/* Back page */}
    <div class="page-wrapper" data-sheet={sheet.num} data-side="back">
      <div class="cards-grid"
           style="display:grid;grid-template-columns:repeat(3,61.33mm);grid-template-rows:repeat(4,67mm);gap:3mm;">
        {sheet.back.map(n => (
          <div class="print-card info-card empty" data-card={n}>
            <div class="info-artist">·</div>
            <div class="info-year">—</div>
            <div class="info-song">·</div>
          </div>
        ))}
      </div>
    </div>

  </>))}
</div>

<!-- ── Script: fill card slots from localStorage ─────────────────────────── -->
<script type="module">
  const { default: QRCode } = await import('https://cdn.jsdelivr.net/npm/qrcode@1.5.4/+esm');

  const MAX_PER_SET = 60;

  const statusEl = document.getElementById('status');
  const infoEl   = document.getElementById('info');
  const btnPrint = document.getElementById('btn-print');
  const setNavEl = document.getElementById('set-nav');

  function setStatus(msg) { statusEl.textContent = msg; }

  // ── Read set data from localStorage ───────────────────────────────────
  let raw = localStorage.getItem('swf_print_sets');
  if (!raw) {
    // Backwards compatibility: check old single-job format
    const oldJob = localStorage.getItem('swf_print_job');
    if (oldJob) {
      try {
        const parsed = JSON.parse(oldJob);
        const migrated = [parsed.slice(0, MAX_PER_SET)];
        localStorage.setItem('swf_print_sets', JSON.stringify(migrated));
        localStorage.removeItem('swf_print_job');
        raw = localStorage.getItem('swf_print_sets');
      } catch {
        setStatus('⚠ Track data corrupted — please go back and regenerate.');
        throw new Error('parse');
      }
    } else {
      setStatus('⚠ No track data found — go back to the admin page and click "Open Print Sheet".');
      throw new Error('missing data');
    }
  }

  let allSets;
  try { allSets = JSON.parse(raw); }
  catch { setStatus('⚠ Track data corrupted — please go back and regenerate.'); throw new Error('parse'); }

  if (!Array.isArray(allSets) || allSets.length === 0) {
    setStatus('⚠ No tracks to print.');
    throw new Error('empty');
  }

  // ── Determine which set to show ───────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  let setIndex = parseInt(params.get('set') ?? '0', 10);
  if (isNaN(setIndex) || setIndex < 0) setIndex = 0;
  if (setIndex >= allSets.length) setIndex = allSets.length - 1;

  const totalSets = allSets.length;
  const tracks = allSets[setIndex];

  if (!Array.isArray(tracks) || tracks.length === 0) {
    setStatus(`⚠ Set ${setIndex + 1} has no tracks.`);
    throw new Error('empty set');
  }

  // ── Show set navigation if multiple sets ──────────────────────────────
  if (totalSets > 1) {
    setNavEl.style.display = 'flex';
    const totalTracks = allSets.reduce((sum, s) => sum + s.length, 0);
    document.getElementById('set-label').textContent =
      `Set ${setIndex + 1} of ${totalSets} (${tracks.length} tracks) — ${totalTracks} total`;

    const btnPrev = document.getElementById('btn-prev-set');
    const btnNext = document.getElementById('btn-next-set');

    btnPrev.disabled = setIndex === 0;
    btnNext.disabled = setIndex === totalSets - 1;

    btnPrev.addEventListener('click', () => {
      if (setIndex > 0) window.location.search = `?set=${setIndex - 1}`;
    });
    btnNext.addEventListener('click', () => {
      if (setIndex < totalSets - 1) window.location.search = `?set=${setIndex + 1}`;
    });
  }

  // ── Fill slots ────────────────────────────────────────────────────────────
  // card slot n (1-indexed) → DOM element helper
  const frontCard = n => document.querySelector(`.qr-card[data-card="${n}"]`);
  const backCard  = n => document.querySelector(`.info-card[data-card="${n}"]`);

  for (let i = 0; i < tracks.length; i++) {
    const t = tracks[i];
    const n = i + 1; // 1-indexed slot

    setStatus(`Generating QR code ${n} of ${tracks.length}…`);

    // Generate QR
    const qrDataUrl = await QRCode.toDataURL(t.uri, {
      width: 300, margin: 2,
      color: { dark: '#000000', light: '#ffffff' },
      errorCorrectionLevel: 'M',
    });

    // Fill front card
    const fc = frontCard(n);
    if (fc) {
      fc.querySelector('.qr-img').src = qrDataUrl;
      fc.classList.remove('empty');
      fc.classList.add('loaded');
    }

    // Fill back card
    const bc = backCard(n);
    if (bc) {
      bc.querySelector('.info-artist').textContent = t.artist || '—';
      bc.querySelector('.info-year').textContent   = t.year   || '—';
      bc.querySelector('.info-song').textContent   = t.name   || '—';
      bc.classList.remove('empty');
      bc.classList.add('loaded');
    }
  }

  // ── Done ──────────────────────────────────────────────────────────────────
  const totalSheets = Math.ceil(tracks.length / 12);
  const setLabel = totalSets > 1 ? ` (Set ${setIndex + 1}/${totalSets})` : '';
  statusEl.style.display = 'none';
  infoEl.textContent =
    `${tracks.length} tracks · ${totalSheets} sheet${totalSheets !== 1 ? 's' : ''} · flip on LONG edge ↔${setLabel}`;
  btnPrint.disabled = false;
</script>
</body>
</html>
