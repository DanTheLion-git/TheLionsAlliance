      <p class="footer__logo">WeddingCamBox</p>
      <p class="footer__tagline" data-i18n="footerTagline">Making wedding memories accessible for everyone.</p>
      <p class="footer__copy"    data-i18n="footerCopy">&copy; 2025 WeddingCamBox. All rights reserved.</p>
    </div>
  </footer>

